{
	"compatibility_date": "2026-04-03",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "bouffonsbios",
	"workers_dev": true,
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"routes": [
		{ "pattern": "bouffonsbios.org", "custom_domain": true },
		{ "pattern": "www.bouffonsbios.org", "custom_domain": true }
	],
	"observability": {
		"enabled": true
	}
}