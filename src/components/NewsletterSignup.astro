---
interface Props {
	/** Contexte transmis à l'API pour savoir d'où vient l'inscription */
	source?: string;
}
const { source = 'site' } = Astro.props;
const formId = `newsletter-form-${source.replace(/[^a-z0-9]/gi, '-')}`;
---

<aside class="newsletter" aria-labelledby={`${formId}-title`}>
	<div class="newsletter__inner">
		<div class="newsletter__head">
			<span class="newsletter__icon" aria-hidden="true">✉</span>
			<div>
				<h2 id={`${formId}-title`} class="newsletter__title">Restez informé·e</h2>
				<p class="newsletter__desc">Lancement du marché, nouveaux vignerons, actu de l'association — un e-mail de temps en temps, sans publicité.</p>
			</div>
		</div>
		<form
			id={formId}
			class="newsletter__form"
			data-source={source}
			novalidate
		>
			<div class="newsletter__row">
				<label for={`${formId}-email`} class="newsletter__label">Votre adresse e-mail</label>
				<div class="newsletter__field">
					<input
						id={`${formId}-email`}
						class="newsletter__input"
						type="email"
						name="email"
						placeholder="vous@exemple.fr"
						autocomplete="email"
						required
						aria-describedby={`${formId}-status`}
					/>
					<button class="newsletter__btn" type="submit">
						<span class="newsletter__btn-label">S'inscrire</span>
						<span class="newsletter__btn-arrow" aria-hidden="true">→</span>
					</button>
				</div>
			</div>
			<p id={`${formId}-status`} class="newsletter__status" role="status" aria-live="polite"></p>
		</form>
	</div>
</aside>

<script>
	document.querySelectorAll<HTMLFormElement>('form[data-source]').forEach((form) => {
		const statusEl = document.getElementById(`${form.id}-status`);
		const input = form.querySelector<HTMLInputElement>('input[type="email"]');
		const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]');

		function setStatus(msg: string, type: 'success' | 'error' | 'info' | '') {
			if (!statusEl) return;
			statusEl.textContent = msg;
			statusEl.dataset.type = type;
		}

		function setLoading(loading: boolean) {
			if (!btn) return;
			btn.disabled = loading;
			btn.classList.toggle('newsletter__btn--loading', loading);
		}

		form.addEventListener('submit', async (e) => {
			e.preventDefault();
			const email = input?.value.trim() ?? '';
			if (!email) {
				setStatus('Veuillez saisir votre adresse e-mail.', 'error');
				input?.focus();
				return;
			}

			const source = form.dataset.source ?? 'site';
			setLoading(true);
			setStatus('', '');

			try {
				const res = await fetch(`/api/newsletter?source=${encodeURIComponent(source)}`, {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ email }),
				});
				const data = await res.json();

				if (!res.ok || !data.ok) {
					setStatus(data.error ?? 'Une erreur est survenue, réessayez.', 'error');
					return;
				}

				if (data.alreadySubscribed) {
					setStatus('Cette adresse est déjà inscrite — à bientôt !', 'info');
				} else {
					setStatus('Inscription confirmée, merci !', 'success');
					form.reset();
				}
			} catch {
				setStatus('Impossible de joindre le serveur, réessayez.', 'error');
			} finally {
				setLoading(false);
			}
		});
	});
</script>

<style>
	.newsletter {
		font-family: var(--font-body, system-ui, sans-serif);
		padding: 1.15rem 1.25rem 1.2rem;
		border-radius: 1.05rem;
		border: 1px solid color-mix(in srgb, var(--border) 75%, var(--accent));
		background: linear-gradient(
			150deg,
			color-mix(in srgb, var(--accent) 7%, var(--bg)),
			color-mix(in srgb, var(--joy) 10%, var(--bg)) 55%,
			var(--bg)
		);
		box-shadow:
			0 1px 0 color-mix(in srgb, var(--joy) 16%, transparent) inset,
			0 6px 22px -12px color-mix(in srgb, var(--accent) 20%, transparent);
	}

	.newsletter__inner {
		display: flex;
		flex-direction: column;
		gap: 0.9rem;
	}

	.newsletter__head {
		display: flex;
		align-items: flex-start;
		gap: 0.75rem;
	}

	.newsletter__icon {
		font-size: 1.25rem;
		line-height: 1;
		flex-shrink: 0;
		margin-top: 0.1rem;
		filter: drop-shadow(0 1px 0 color-mix(in srgb, var(--accent) 20%, transparent));
	}

	.newsletter__title {
		margin: 0 0 0.22rem;
		font-family: var(--font-display, Georgia, serif);
		font-size: 1rem;
		font-weight: 800;
		line-height: 1.2;
		letter-spacing: -0.015em;
		color: var(--accent);
		text-rendering: optimizeLegibility;
	}

	.newsletter__desc {
		margin: 0;
		font-size: 0.84rem;
		line-height: 1.45;
		color: var(--muted);
	}

	.newsletter__form {
		display: flex;
		flex-direction: column;
		gap: 0.45rem;
	}

	.newsletter__row {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
	}

	.newsletter__label {
		font-size: 0.75rem;
		font-weight: 600;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--muted);
	}

	.newsletter__field {
		display: flex;
		gap: 0;
		border-radius: 0.65rem;
		border: 1.5px solid color-mix(in srgb, var(--border) 90%, var(--accent));
		overflow: hidden;
		background: color-mix(in srgb, var(--bg) 70%, transparent);
		transition: border-color 0.18s ease, box-shadow 0.18s ease;
	}

	.newsletter__field:focus-within {
		border-color: var(--accent);
		box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 15%, transparent);
	}

	.newsletter__input {
		flex: 1;
		min-width: 0;
		padding: 0.6rem 0.75rem;
		border: none;
		background: transparent;
		color: var(--fg);
		font-family: inherit;
		font-size: 0.9rem;
		outline: none;
	}

	.newsletter__input::placeholder {
		color: color-mix(in srgb, var(--muted) 65%, transparent);
	}

	.newsletter__btn {
		flex-shrink: 0;
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
		padding: 0.6rem 0.9rem;
		border: none;
		border-left: 1.5px solid color-mix(in srgb, var(--border) 90%, var(--accent));
		background: linear-gradient(
			145deg,
			color-mix(in srgb, var(--accent) 92%, #fff),
			var(--accent)
		);
		color: #fff;
		font-family: inherit;
		font-size: 0.88rem;
		font-weight: 600;
		cursor: pointer;
		transition:
			filter 0.15s ease,
			background 0.15s ease;
	}

	.newsletter__btn:hover:not(:disabled) {
		filter: brightness(1.08);
	}

	.newsletter__btn:disabled {
		opacity: 0.65;
		cursor: default;
	}

	.newsletter__btn--loading .newsletter__btn-label::after {
		content: '…';
	}

	.newsletter__btn--loading .newsletter__btn-arrow {
		display: none;
	}

	.newsletter__btn-arrow {
		color: var(--joy-soft, #e4b86a);
		font-size: 1rem;
		transition: transform 0.15s ease;
	}

	.newsletter__btn:hover:not(:disabled) .newsletter__btn-arrow {
		transform: translateX(2px);
	}

	.newsletter__status {
		margin: 0;
		font-size: 0.84rem;
		line-height: 1.4;
		min-height: 1.2em;
	}

	.newsletter__status[data-type='success'] {
		color: var(--accent-nature);
		font-weight: 600;
	}

	.newsletter__status[data-type='error'] {
		color: var(--accent);
	}

	.newsletter__status[data-type='info'] {
		color: var(--joy, #c9892e);
	}

</style>
