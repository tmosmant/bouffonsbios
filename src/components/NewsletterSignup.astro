---
interface Props {
	/** Contexte transmis à l'API pour savoir d'où vient l'inscription */
	source?: string;
}
const { source = 'site' } = Astro.props;
const formId = `newsletter-form-${source.replace(/[^a-z0-9]/gi, '-')}`;
---

<aside class="newsletter" aria-labelledby={`${formId}-title`}>
	<div class="newsletter__inner">
		<p class="newsletter__kicker">Newsletter</p>
		<h2 id={`${formId}-title`} class="newsletter__title">Restez informé·e</h2>
		<p class="newsletter__desc">
			Lancement du marché, nouveaux vignerons, actu de l'association — un e-mail de temps en temps, sans pub.
		</p>
		<form id={formId} class="newsletter__form" data-source={source} novalidate>
			<div class="newsletter__row">
				<label for={`${formId}-name`} class="newsletter__label">Prénom et nom</label>
				<input
					id={`${formId}-name`}
					class="newsletter__input"
					type="text"
					name="name"
					placeholder="Camille Dupont"
					autocomplete="name"
					maxlength="120"
					required
					aria-describedby={`${formId}-status`}
				/>
			</div>
			<div class="newsletter__row">
				<label for={`${formId}-email`} class="newsletter__label">Adresse e-mail</label>
				<input
					id={`${formId}-email`}
					class="newsletter__input"
					type="email"
					name="email"
					placeholder="vous@exemple.fr"
					autocomplete="email"
					required
					aria-describedby={`${formId}-status`}
				/>
			</div>
			<button class="newsletter__btn" type="submit">S'inscrire</button>
			<p id={`${formId}-status`} class="newsletter__status" role="status" aria-live="polite"></p>
		</form>
	</div>
</aside>

<script>
	document.querySelectorAll<HTMLFormElement>('form[data-source]').forEach((form) => {
		const statusEl = document.getElementById(`${form.id}-status`);
		const nameInput = form.querySelector<HTMLInputElement>('input[name="name"]');
		const input = form.querySelector<HTMLInputElement>('input[type="email"]');
		const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]');

		function setStatus(msg: string, type: 'success' | 'error' | 'info' | '') {
			if (!statusEl) return;
			statusEl.textContent = msg;
			statusEl.dataset.type = type;
		}

		function setLoading(loading: boolean) {
			if (!btn) return;
			btn.disabled = loading;
			btn.classList.toggle('newsletter__btn--loading', loading);
		}

		form.addEventListener('submit', async (e) => {
			e.preventDefault();
			const name = nameInput?.value.trim().replace(/\s+/g, ' ') ?? '';
			if (!name) {
				setStatus('Veuillez indiquer votre prénom et nom.', 'error');
				nameInput?.focus();
				return;
			}
			const email = input?.value.trim() ?? '';
			if (!email) {
				setStatus('Veuillez saisir votre adresse e-mail.', 'error');
				input?.focus();
				return;
			}

			const source = form.dataset.source ?? 'site';
			setLoading(true);
			setStatus('', '');

			try {
				const res = await fetch(`/api/newsletter?source=${encodeURIComponent(source)}`, {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ email, name }),
				});
				const data = await res.json();

				if (!res.ok || !data.ok) {
					setStatus(data.error ?? 'Une erreur est survenue, réessayez.', 'error');
					return;
				}

				if (data.alreadySubscribed) {
					setStatus('Cette adresse est déjà inscrite — à bientôt !', 'info');
				} else {
					setStatus('Inscription confirmée, merci !', 'success');
					form.reset();
				}
			} catch {
				setStatus('Impossible de joindre le serveur, réessayez.', 'error');
			} finally {
				setLoading(false);
			}
		});
	});
</script>

<style>
	/* Même langage que l’encart presse : crème, vigne, pas d’icône décorative */
	.newsletter {
		font-family: var(--font-body, system-ui, sans-serif);
		margin: 0;
		padding: 1.1rem 1rem 1.15rem;
		border-radius: 1.05rem;
		border: 1px solid color-mix(in srgb, var(--border) 72%, var(--accent-nature));
		background: linear-gradient(
			165deg,
			color-mix(in srgb, var(--joy) 10%, var(--bg)),
			color-mix(in srgb, var(--accent-nature) 7%, var(--bg)) 55%,
			var(--bg)
		);
		box-shadow:
			0 1px 0 color-mix(in srgb, var(--joy) 12%, transparent) inset,
			0 8px 28px -14px color-mix(in srgb, var(--accent) 22%, transparent);
	}

	.newsletter__inner {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.newsletter__kicker {
		margin: 0;
		font-size: 0.65rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--accent, #8f2d4a);
	}

	.newsletter__title {
		margin: 0;
		font-family: var(--font-display, Georgia, serif);
		font-size: 1.05rem;
		font-weight: 800;
		line-height: 1.2;
		letter-spacing: -0.01em;
		color: var(--accent-nature, #35624a);
		text-rendering: optimizeLegibility;
	}

	.newsletter__desc {
		margin: 0;
		font-size: 0.82rem;
		line-height: 1.45;
		color: var(--muted, #5c5850);
	}

	.newsletter__form {
		display: flex;
		flex-direction: column;
		gap: 0.55rem;
		margin-top: 0.15rem;
	}

	.newsletter__row {
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
	}

	.newsletter__label {
		font-size: 0.72rem;
		font-weight: 600;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: var(--muted, #5c5850);
	}

	.newsletter__input {
		width: 100%;
		padding: 0.58rem 0.72rem;
		border-radius: 0.65rem;
		border: 1px solid color-mix(in srgb, var(--border) 88%, var(--accent-nature));
		background: color-mix(in srgb, var(--bg) 65%, transparent);
		color: var(--fg);
		font-family: inherit;
		font-size: 0.9rem;
		outline: none;
		transition:
			border-color 0.18s ease,
			box-shadow 0.18s ease;
	}

	.newsletter__input::placeholder {
		color: color-mix(in srgb, var(--muted) 62%, transparent);
	}

	.newsletter__input:focus {
		border-color: color-mix(in srgb, var(--accent-nature) 45%, var(--border));
		box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-nature) 12%, transparent);
	}

	.newsletter__btn {
		width: 100%;
		padding: 0.58rem 1rem;
		border-radius: 0.65rem;
		border: 1px solid color-mix(in srgb, var(--accent-nature) 35%, var(--border));
		background: linear-gradient(
			180deg,
			color-mix(in srgb, var(--accent-nature) 12%, var(--bg)),
			color-mix(in srgb, var(--accent-nature) 6%, var(--bg))
		);
		color: var(--accent-nature, #35624a);
		font-family: inherit;
		font-size: 0.88rem;
		font-weight: 700;
		cursor: pointer;
		transition:
			background 0.18s ease,
			border-color 0.18s ease,
			color 0.18s ease;
	}

	.newsletter__btn:hover:not(:disabled) {
		background: linear-gradient(
			180deg,
			color-mix(in srgb, var(--accent-nature) 22%, var(--bg)),
			color-mix(in srgb, var(--accent-nature) 14%, var(--bg))
		);
		border-color: var(--accent-nature, #35624a);
		color: var(--fg, #1c221c);
	}

	.newsletter__btn:disabled {
		opacity: 0.65;
		cursor: default;
	}

	.newsletter__btn--loading {
		pointer-events: none;
	}

	.newsletter__btn--loading::after {
		content: '…';
	}

	.newsletter__status {
		margin: 0;
		font-size: 0.82rem;
		line-height: 1.4;
		min-height: 1.25em;
	}

	.newsletter__status[data-type='success'] {
		color: var(--accent-nature);
		font-weight: 600;
	}

	.newsletter__status[data-type='error'] {
		color: var(--accent);
	}

	.newsletter__status[data-type='info'] {
		color: var(--joy, #c9892e);
		font-weight: 600;
	}

</style>
