---
import { NAV_HIGHLIGHT } from '../site-config';

interface Props {
	title: string;
	description?: string;
	/** Lien actif dans la barre principale */
	current?: 'highlight' | 'articles' | 'manifeste' | 'contact' | 'plan';
	/** Classes additionnelles sur `<main>` (ex. `site-main--home` pour la grille d’accueil) */
	mainClass?: string;
}

const { title, description = 'Bouffons Bios — association', current, mainClass } = Astro.props;

const nav = [
	{ id: 'highlight' as const, href: NAV_HIGHLIGHT.href, label: NAV_HIGHLIGHT.label },
	{ id: 'articles' as const, href: '/articles/', label: 'Articles' },
	{ id: 'manifeste' as const, href: '/manifeste/', label: 'Manifeste' },
	{ id: 'contact' as const, href: '/contact/', label: 'Contact' },
	{ id: 'plan' as const, href: '/plan-dacces/', label: "Plan d'accès" },
];
---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		{description && <meta name="description" content={description} />}
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,500..900;1,9..144,500..800&family=Source+Sans+3:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap"
			rel="stylesheet"
		/>
		<slot name="head" />
	</head>
	<body>
		<a href="#contenu" class="skip">Aller au contenu</a>
		<header class="site-head">
			<div class="site-brand">
				<a class="logo" href="/">Bouffons Bios</a>
			</div>
			<nav class="site-nav" aria-label="Navigation principale">
				<ul>
					{
						nav.map((item) => (
							<li>
								{item.id === 'highlight' ? (
									<a
										href={item.href}
										class:list={['nav-link--highlight', { active: current === item.id }]}
									>
										{item.label}
									</a>
								) : (
									<a href={item.href} class:list={[{ active: current === item.id }]}>
										{item.label}
									</a>
								)}
							</li>
						))
					}
				</ul>
			</nav>
		</header>
		<main id="contenu" class:list={['site-main', mainClass]}>
			<slot />
		</main>
		<footer class="site-footer">
			<p>Association Bouffons Bios — <a href="/contact/">Contact</a></p>
		</footer>
	</body>
</html>

<style is:global>
	:root {
		color-scheme: light dark;
		--font-body: 'Source Sans 3', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
		--font-display: 'Fraunces', Georgia, 'Times New Roman', serif;
		/* chaud : crème, vin, vigne, un peu de miel (fête) */
		--bg: #f6f1e8;
		--fg: #1c221c;
		--accent: #8f2d4a;
		--accent-soft: #a84862;
		--accent-nature: #35624a;
		--accent-nature-soft: #4a7d62;
		--joy: #c9892e;
		--joy-soft: #e4b86a;
		--muted: #5a5c52;
		--border: #dcd4c8;
		--nav-bg: color-mix(in srgb, #e8efe8 65%, var(--bg));
		font-family: var(--font-body);
		line-height: 1.62;
	}

	@media (prefers-color-scheme: dark) {
		:root {
			--bg: #151a16;
			--fg: #f2eee6;
			--accent: #e8a0b3;
			--accent-soft: #f0b8c8;
			--accent-nature: #8fbc9f;
			--accent-nature-soft: #a8d4b8;
			--joy: #e8c15a;
			--joy-soft: #f0d080;
			--muted: #a8a99e;
			--border: #2d332e;
			--nav-bg: color-mix(in srgb, #1c261f 80%, var(--bg));
		}
	}

	* {
		box-sizing: border-box;
	}

	html {
		background:
			radial-gradient(ellipse 90% 55% at 100% -5%, color-mix(in srgb, var(--joy) 14%, transparent), transparent 52%),
			radial-gradient(ellipse 75% 50% at -8% 25%, color-mix(in srgb, var(--accent-nature) 12%, transparent), transparent 48%),
			radial-gradient(ellipse 65% 45% at 85% 95%, color-mix(in srgb, var(--accent) 9%, transparent), transparent 55%),
			var(--bg);
		background-attachment: fixed;
		color: var(--fg);
	}

	body {
		margin: 0;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
	}

	.skip {
		position: absolute;
		left: -9999px;
	}
	.skip:focus {
		left: 1rem;
		top: 1rem;
		z-index: 999;
		padding: 0.5rem 1rem;
		background: var(--accent);
		color: var(--bg);
	}

	.site-head {
		border-bottom: 1px solid color-mix(in srgb, var(--border) 88%, var(--accent-nature));
		background: color-mix(in srgb, var(--bg) 92%, white);
		box-shadow: 0 1px 0 color-mix(in srgb, var(--joy) 8%, transparent);
	}

	@media (prefers-color-scheme: dark) {
		.site-head {
			background: color-mix(in srgb, var(--bg) 85%, transparent);
			box-shadow: 0 1px 0 color-mix(in srgb, var(--accent-nature) 12%, transparent);
		}
	}

	.site-brand {
		padding: 1rem 1.25rem 0.6rem;
	}

	.logo {
		font-family: var(--font-display);
		/* Android / Edge : graisses « rondes » (600/700/800) + axe wght explicite ; éviter 650 et WONK > 0 (fûts trop fins). */
		font-weight: 800;
		font-size: 1.35rem;
		color: var(--fg);
		text-decoration: none;
		letter-spacing: -0.012em;
		font-variation-settings: 'wght' 800, 'SOFT' 70, 'WONK' 0;
		font-optical-sizing: auto;
		text-rendering: optimizeLegibility;
	}
	.logo:hover {
		color: var(--accent);
	}

	.site-nav {
		background: linear-gradient(
			180deg,
			color-mix(in srgb, var(--nav-bg) 100%, transparent) 0%,
			color-mix(in srgb, var(--joy) 4%, var(--nav-bg)) 100%
		);
		border-top: 1px solid color-mix(in srgb, var(--border) 90%, var(--joy));
		overflow-x: auto;
		-webkit-overflow-scrolling: touch;
	}

	.site-nav ul {
		display: flex;
		flex-wrap: nowrap;
		gap: 0;
		margin: 0;
		padding: 0 0.5rem;
		list-style: none;
		min-height: 2.85rem;
		align-items: stretch;
	}

	.site-nav li {
		display: flex;
		flex-shrink: 0;
	}

	.site-nav a {
		display: flex;
		align-items: center;
		padding: 0.65rem 0.9rem;
		color: var(--muted);
		text-decoration: none;
		font-size: 0.9rem;
		font-weight: 500;
		border-bottom: 2px solid transparent;
		white-space: nowrap;
		max-width: 16rem;
		line-height: 1.25;
	}

	.site-nav a:hover {
		color: var(--accent);
		background: linear-gradient(
			180deg,
			color-mix(in srgb, var(--accent) 7%, transparent),
			color-mix(in srgb, var(--accent-nature) 8%, transparent)
		);
	}

	.site-nav a.active {
		color: var(--accent);
		font-weight: 600;
		border-bottom: 2px solid var(--joy);
		box-shadow: inset 0 -3px 0 -1px var(--accent-nature);
	}

	/* À la une : même famille que le logo, une seule couleur — se démarque sans fragmenter la phrase */
	.site-nav a.nav-link--highlight {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: clamp(0.875rem, 2vw, 0.9rem);
		letter-spacing: -0.018em;
		color: var(--accent);
		font-variation-settings: 'wght' 700, 'SOFT' 70, 'WONK' 0;
		font-optical-sizing: auto;
		max-width: min(20rem, 85vw);
		white-space: normal;
		line-height: 1.2;
		hyphens: auto;
	}

	.site-nav a.nav-link--highlight:hover {
		color: var(--accent-soft);
	}

	.site-main {
		flex: 1;
		width: 100%;
		max-width: 46rem;
		margin: 0 auto;
		padding: 2rem 1.5rem 3rem;
	}

	/* Accueil : colonne principale + encart presse */
	.site-main--home {
		max-width: min(70rem, 100%);
		display: grid;
		gap: 1.75rem;
		align-items: start;
	}

	@media (min-width: 56rem) {
		.site-main--home {
			grid-template-columns: minmax(0, 1fr) minmax(15.25rem, 18rem);
			column-gap: 2rem;
		}
	}

	/* Fiches article : colonne un peu plus étroite pour le confort de lecture */
	.site-main--article {
		max-width: 38rem;
	}

	.site-footer {
		padding: 1.35rem 1.5rem;
		border-top: 1px solid color-mix(in srgb, var(--border) 85%, var(--accent-nature));
		background: linear-gradient(
			180deg,
			color-mix(in srgb, var(--joy) 6%, transparent),
			color-mix(in srgb, var(--accent-nature) 5%, transparent)
		);
		text-align: center;
		color: var(--muted);
		font-size: 0.88rem;
	}

	.site-footer p {
		margin: 0;
	}

	.site-footer a {
		color: var(--accent);
	}

	.prose :where(h1) {
		font-family: var(--font-display);
		font-weight: 800;
		line-height: 1.18;
		letter-spacing: -0.012em;
		font-variation-settings: 'wght' 800, 'SOFT' 70, 'WONK' 0;
		font-optical-sizing: auto;
		text-rendering: optimizeLegibility;
	}
	.prose :where(h2) {
		font-family: var(--font-body);
		font-weight: 700;
		line-height: 1.28;
		color: var(--accent-nature);
		letter-spacing: -0.01em;
	}
	.prose :where(h3) {
		font-family: var(--font-body);
		font-weight: 600;
		line-height: 1.3;
		color: color-mix(in srgb, var(--accent) 85%, var(--fg));
	}
	.prose :where(p) {
		margin: 0 0 1em;
	}
	.prose :where(a) {
		color: var(--accent);
		font-weight: 500;
		text-decoration: underline;
		text-decoration-thickness: 0.08em;
		text-underline-offset: 0.2em;
		transition:
			color 0.15s ease,
			text-decoration-color 0.15s ease;
	}
	.prose :where(a):hover {
		color: color-mix(in srgb, var(--accent) 55%, var(--joy));
		text-decoration-color: var(--joy);
	}
	.prose :where(strong) {
		color: color-mix(in srgb, var(--fg) 70%, var(--accent));
		font-weight: 600;
	}
	.prose :where(blockquote) {
		margin: 1.25rem 0;
		padding: 0.85rem 1rem 0.85rem 1.1rem;
		border-left: 4px solid var(--accent-nature);
		border-radius: 0 0.65rem 0.65rem 0;
		background: linear-gradient(
			135deg,
			color-mix(in srgb, var(--accent-nature) 9%, transparent),
			color-mix(in srgb, var(--joy) 6%, transparent)
		);
		font-style: italic;
		color: var(--muted);
	}
	.prose :where(ul) {
		padding-left: 1.2rem;
	}
	.prose :where(ul > li::marker) {
		color: var(--accent-nature-soft);
	}
	.prose :where(ol > li::marker) {
		color: var(--joy);
		font-weight: 600;
	}
	.prose :where(img) {
		border-radius: 0.75rem;
		box-shadow:
			0 2px 12px color-mix(in srgb, var(--fg) 8%, transparent),
			0 0 0 1px color-mix(in srgb, var(--border) 80%, var(--accent-nature));
	}
	.prose :where(hr) {
		border: none;
		height: 2px;
		margin: 2rem 0;
		border-radius: 2px;
		background: linear-gradient(90deg, transparent, var(--accent-nature), var(--joy), var(--accent), transparent);
		opacity: 0.45;
	}
	.prose :where(code) {
		font-size: 0.92em;
		padding: 0.12em 0.35em;
		border-radius: 0.35rem;
		background: color-mix(in srgb, var(--accent-nature) 10%, var(--border));
		color: var(--fg);
	}
	.prose :where(pre code) {
		padding: 0;
		background: none;
	}
	.prose :where(pre) {
		padding: 1rem;
		border-radius: 0.65rem;
		border: 1px solid var(--border);
		background: color-mix(in srgb, var(--bg) 70%, var(--nav-bg));
		overflow-x: auto;
	}
</style>
