---
import { getEntry } from 'astro:content';
import SiteFlash from '../components/SiteFlash.astro';

interface OpenGraphProps {
	/** Titre pour le partage (sinon = title de la page) */
	title?: string;
	/** Texte pour le partage (sinon = meta description) */
	description?: string;
	/** Chemin absolu sur le site, ex. /uploads/affiche.jpg */
	image?: string;
	/** Texte alternatif de l’image (accessibilité / aperçus) */
	imageAlt?: string;
	type?: 'website' | 'article';
}

interface Props {
	title: string;
	description?: string;
	/** Lien actif dans la barre principale (identifiant `id` du lien dans navigation.json) */
	current?: string;
	/** Classes additionnelles sur `<main>` (ex. `site-main--home` pour la grille d’accueil) */
	mainClass?: string;
	/** Open Graph / Twitter / réseaux sociaux */
	openGraph?: OpenGraphProps;
}

const { title, description = 'Bouffons Bios — association', current, mainClass, openGraph } = Astro.props;

const flashEntry = await getEntry('flash', 'flash');
if (!flashEntry) {
	throw new Error('Fichier src/content/flash.json introuvable ou clé « flash » manquante.');
}
const flashData = flashEntry.data;
const showFlashGlobal =
	flashData.enabled &&
	flashData.showOnAllPages &&
	flashData.bodyMarkdown.trim().length > 0;

const site = Astro.site ?? new URL('https://bouffonsbios.org');
const canonicalURL = new URL(Astro.url.pathname || '/', site);
const ogTitle = openGraph?.title ?? title;
const ogDescription = (openGraph?.description ?? description)?.trim() || undefined;
const ogType = openGraph?.type ?? 'website';
const ogImageAbsolute =
	openGraph?.image != null && openGraph.image !== ''
		? new URL(openGraph.image.replace(/^\//, ''), site).href
		: undefined;
const ogImageAlt = openGraph?.imageAlt?.trim() || ogTitle;
const twitterCard = ogImageAbsolute ? 'summary_large_image' : 'summary';

const navEntry = await getEntry('navigation', 'nav');
if (!navEntry) {
	throw new Error('Fichier src/content/navigation.json introuvable ou clé « nav » manquante.');
}
const nav = navEntry.data.items;

function navHrefIsExternal(href: string): boolean {
	return /^https?:\/\//i.test(href.trim());
}
---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="color-scheme" content="light only" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		{description && <meta name="description" content={description} />}
		<link rel="canonical" href={canonicalURL.href} />
		<meta property="og:site_name" content="Bouffons Bios" />
		<meta property="og:locale" content="fr_FR" />
		<meta property="og:type" content={ogType} />
		<meta property="og:url" content={canonicalURL.href} />
		<meta property="og:title" content={ogTitle} />
		{ogDescription && <meta property="og:description" content={ogDescription} />}
		{ogImageAbsolute && (
			<>
				<meta property="og:image" content={ogImageAbsolute} />
				<meta property="og:image:alt" content={ogImageAlt} />
			</>
		)}
		<meta name="twitter:card" content={twitterCard} />
		<meta name="twitter:title" content={ogTitle} />
		{ogDescription && <meta name="twitter:description" content={ogDescription} />}
		{ogImageAbsolute && <meta name="twitter:image" content={ogImageAbsolute} />}
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,700;0,800;1,700;1,800&family=Source+Sans+3:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap"
			rel="stylesheet"
		/>
		<slot name="head" />
	</head>
	<body>
		<a href="#contenu" class="skip">Aller au contenu</a>
		<header class="site-head">
			<div class="site-head-inner">
				<div class="site-brand">
					<a class="logo" href="/">Bouffons Bios</a>
				</div>
				<nav class="site-nav" aria-label="Navigation principale">
					<ul>
						{
							nav.map((item) => {
								const external = navHrefIsExternal(item.href);
								return (
									<li>
										{item.emphasized ? (
											<a
												href={item.href}
												class:list={['nav-link--highlight', { active: current === item.id }]}
												{...(external
													? { target: '_blank', rel: 'noopener noreferrer' }
													: {})}
											>
												{item.title}
											</a>
										) : (
											<a
												href={item.href}
												class:list={[{ active: current === item.id }]}
												{...(external
													? { target: '_blank', rel: 'noopener noreferrer' }
													: {})}
											>
												{item.title}
											</a>
										)}
									</li>
								);
							})
						}
					</ul>
				</nav>
				<div class="site-head-deco" aria-hidden="true">
					<svg class="site-head-deco-svg" viewBox="0 0 120 100" fill="none" xmlns="http://www.w3.org/2000/svg">
						<path
							d="M60 8c-12 8-22 22-24 38-2 14 6 28 18 34M44 52c-8 6-12 16-10 26 2 12 12 20 24 22M76 48c10-4 18-14 20-26 2-14-4-28-16-36"
							stroke="currentColor"
							stroke-width="2.2"
							stroke-linecap="round"
							opacity="0.35"
						/>
						<ellipse cx="58" cy="72" rx="10" ry="14" transform="rotate(-28 58 72)" fill="currentColor" opacity="0.2" />
						<ellipse cx="78" cy="64" rx="8" ry="11" transform="rotate(12 78 64)" fill="currentColor" opacity="0.16" />
						<ellipse cx="42" cy="68" rx="7" ry="10" transform="rotate(-8 42 68)" fill="currentColor" opacity="0.18" />
					</svg>
				</div>
			</div>
		</header>
		<main id="contenu" class:list={['site-main', mainClass]}>
			{
				showFlashGlobal && (
					<SiteFlash
						title={flashData.title}
						bodyMarkdown={flashData.bodyMarkdown}
						linkLabel={flashData.linkLabel}
						linkHref={flashData.linkHref}
						placement="global"
					/>
				)
			}
			<slot />
		</main>
		<footer class="site-footer">
			<p>Association Bouffons Bios — <a href="/contact/">Contact</a></p>
		</footer>
		<script is:inline>
			console.info(
				'%cBouffons Bios%c — Pas de revente de données, pas de pubs cachées. Développement buvable.',
				'font-weight:700;color:#35624a;',
				'color:inherit;',
			);
		</script>
	</body>
</html>

<style is:global>
	:root {
		/* Pas de thème sombre : uniquement clair (UI navigateur + page). */
		color-scheme: light only;
		--font-body: 'Source Sans 3', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
		--font-display: 'Fraunces', Georgia, 'Times New Roman', serif;
		/* chaud : crème, vin, vigne, un peu de miel (fête) */
		--bg: #f6f1e8;
		--fg: #1c221c;
		--accent: #8f2d4a;
		--accent-soft: #a84862;
		--accent-nature: #35624a;
		--accent-nature-soft: #4a7d62;
		--joy: #c9892e;
		--joy-soft: #e4b86a;
		--muted: #5a5c52;
		--border: #dcd4c8;
		--nav-bg: color-mix(in srgb, #e8efe8 65%, var(--bg));
		font-family: var(--font-body);
		line-height: 1.62;
	}

	* {
		box-sizing: border-box;
	}

	/*
	 * Fonds organiques : taches vin + « feuilles » (ellipses allongées en coins).
	 * Valeurs volontairement visibles ; on reste sous les blocs de contenu.
	 */
	html {
		background:
			radial-gradient(ellipse 58% 44% at 102% -2%, color-mix(in srgb, var(--joy) 24%, transparent), transparent 58%),
			radial-gradient(ellipse 50% 36% at 92% 99%, color-mix(in srgb, var(--accent) 18%, transparent), transparent 56%),
			radial-gradient(ellipse 54% 42% at -8% 20%, color-mix(in srgb, var(--accent-nature) 22%, transparent), transparent 58%),
			radial-gradient(ellipse 42% 32% at 40% 78%, color-mix(in srgb, var(--joy) 12%, transparent), transparent 54%),
			radial-gradient(ellipse 34% 26% at 70% 40%, color-mix(in srgb, var(--accent) 14%, transparent), transparent 50%),
			radial-gradient(ellipse 28% 22% at 14% 52%, color-mix(in srgb, var(--accent) 12%, transparent), transparent 48%),
			url("data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 400 400%22%3E%3Cg fill=%22%232f5c44%22%3E%3Cellipse cx=%22310%22 cy=%2270%22 rx=%2255%22 ry=%2288%22 transform=%22rotate%28-35 310 70%29%22 opacity=%22.22%22/%3E%3Cellipse cx=%22340%22 cy=%22130%22 rx=%2232%22 ry=%2252%22 transform=%22rotate%2815 340 130%29%22 opacity=%22.18%22/%3E%3C/g%3E%3Cg fill=%22%237a2840%22%3E%3Cellipse cx=%22330%22 cy=%22320%22 rx=%2272%22 ry=%2238%22 transform=%22rotate%2818 330 320%29%22 opacity=%22.2%22/%3E%3Cellipse cx=%2270%22 cy=%22100%22 rx=%2230%22 ry=%2222%22 transform=%22rotate%28-25 70 100%29%22 opacity=%22.16%22/%3E%3C/g%3E%3Cg fill=%22%2335624a%22%3E%3Cellipse cx=%2290%22 cy=%22300%22 rx=%2248%22 ry=%2272%22 transform=%22rotate%2840 90 300%29%22 opacity=%22.2%22/%3E%3Cellipse cx=%22220%22 cy=%22240%22 rx=%2236%22 ry=%2258%22 transform=%22rotate%28-55 220 240%29%22 opacity=%22.14%22/%3E%3C/g%3E%3C/svg%3E")
				center / min(110vmin, 78rem) no-repeat,
			var(--bg);
		background-attachment: fixed;
		color: var(--fg);
	}

	body {
		margin: 0;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
	}

	.skip {
		position: absolute;
		left: -9999px;
	}
	.skip:focus {
		left: 1rem;
		top: 1rem;
		z-index: 999;
		padding: 0.5rem 1rem;
		background: var(--accent);
		color: var(--bg);
	}

	.site-head {
		border-bottom: 1px solid color-mix(in srgb, var(--border) 88%, var(--accent-nature));
		background: color-mix(in srgb, var(--bg) 92%, white);
		box-shadow: 0 1px 0 color-mix(in srgb, var(--joy) 8%, transparent);
	}

	.site-head-inner {
		max-width: min(70rem, 100%);
		margin: 0 auto;
	}

	.site-head-deco {
		display: none;
	}

	@media (min-width: 56rem) {
		.site-head-inner {
			display: grid;
			grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
			align-items: center;
			gap: 0.75rem 1.25rem;
			padding: 0 1.25rem;
		}

		.site-brand {
			justify-self: start;
			padding: 0.95rem 0;
		}

		.site-nav {
			justify-self: center;
			grid-column: 2;
			max-width: 100%;
			border-top: none;
			border-radius: 999px;
			border: 1px solid color-mix(in srgb, var(--border) 78%, var(--accent-nature));
			box-shadow:
				0 1px 0 color-mix(in srgb, white 55%, transparent) inset,
				0 6px 22px -14px color-mix(in srgb, var(--accent) 18%, transparent);
			background: linear-gradient(
				165deg,
				color-mix(in srgb, var(--bg) 88%, white) 0%,
				color-mix(in srgb, var(--joy) 6%, var(--nav-bg)) 100%
			);
			display: flex;
			align-items: stretch;
			min-height: 2.85rem;
			padding: 0;
		}

		.site-head-deco {
			justify-self: end;
			display: flex;
			align-items: center;
			color: var(--accent-nature-soft);
			opacity: 0.85;
		}

		.site-head-deco-svg {
			width: clamp(3.25rem, 5vw, 4.25rem);
			height: auto;
		}
	}

	.site-brand {
		padding: 1rem 1.25rem 0.6rem;
	}

	.logo {
		font-family: var(--font-display);
		/* Fraunces en fichiers statiques 700/800 (pas variable opsz/wght) : rendu plus stable sur Chromium Android / Edge. */
		font-weight: 800;
		font-size: 1.35rem;
		color: var(--fg);
		text-decoration: none;
		letter-spacing: -0.012em;
		text-rendering: optimizeLegibility;
	}
	.logo:hover {
		color: var(--accent);
	}

	.site-nav {
		background: linear-gradient(
			180deg,
			color-mix(in srgb, var(--nav-bg) 100%, transparent) 0%,
			color-mix(in srgb, var(--joy) 4%, var(--nav-bg)) 100%
		);
		border-top: 1px solid color-mix(in srgb, var(--border) 90%, var(--joy));
		overflow-x: auto;
		-webkit-overflow-scrolling: touch;
	}

	.site-nav ul {
		display: flex;
		flex-wrap: nowrap;
		gap: 0;
		margin: 0;
		padding: 0 0.5rem;
		list-style: none;
		min-height: 2.85rem;
		align-items: stretch;
	}

	.site-nav li {
		display: flex;
		flex-shrink: 0;
	}

	.site-nav a {
		display: flex;
		align-items: center;
		padding: 0.65rem 0.9rem;
		color: var(--muted);
		text-decoration: none;
		font-size: 0.9rem;
		font-weight: 500;
		border-bottom: 2px solid transparent;
		white-space: nowrap;
		max-width: 16rem;
		line-height: 1.25;
	}

	.site-nav a:hover {
		color: var(--accent);
		background: linear-gradient(
			180deg,
			color-mix(in srgb, var(--accent) 7%, transparent),
			color-mix(in srgb, var(--accent-nature) 8%, transparent)
		);
	}

	.site-nav a.active {
		color: var(--accent);
		font-weight: 600;
		border-bottom: 2px solid var(--joy);
		box-shadow: inset 0 -3px 0 -1px var(--accent-nature);
	}

	/* À la une : même famille que le logo, une seule couleur — se démarque sans fragmenter la phrase */
	.site-nav a.nav-link--highlight {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: clamp(0.875rem, 2vw, 0.9rem);
		letter-spacing: -0.018em;
		color: var(--accent);
		max-width: min(20rem, 85vw);
		white-space: normal;
		line-height: 1.2;
		hyphens: auto;
	}

	.site-nav a.nav-link--highlight:hover {
		color: var(--accent-soft);
	}

	/* Pilule desktop : liens hauteur pleine, premier / dernier jusqu’au bord arrondi (après les styles de base). */
	@media (min-width: 56rem) {
		.site-nav ul {
			padding: 0;
			min-height: 100%;
			flex: 1 1 auto;
			align-items: stretch;
			flex-wrap: nowrap;
			justify-content: center;
		}

		.site-nav li {
			align-items: stretch;
		}

		.site-nav a {
			padding: 0 0.85rem;
			min-height: 2.85rem;
			align-self: stretch;
			border-radius: 0;
			box-sizing: border-box;
		}

		.site-nav li:first-child a {
			padding-left: 1.15rem;
			border-top-left-radius: 999px;
			border-bottom-left-radius: 999px;
		}

		.site-nav li:last-child a {
			padding-right: 1.15rem;
			border-top-right-radius: 999px;
			border-bottom-right-radius: 999px;
		}
	}

	/* Accueil & pages pleine largeur de contenu (70rem) */
	.site-main {
		flex: 1;
		width: 100%;
		max-width: min(70rem, 100%);
		margin: 0 auto;
		padding: 2rem 1.5rem 3rem;
	}

	/* Articles, manifeste, contact, plan : colonne de lecture plus étroite */
	.site-main--narrow {
		max-width: min(44rem, 100%);
	}

	/* Accueil : bandeau flash pleine largeur au-dessus, puis grille dans `.home-columns` (index) */
	.site-main--home {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		align-items: stretch;
	}

	.site-footer {
		padding: 1.35rem 1.5rem;
		border-top: 1px solid color-mix(in srgb, var(--border) 85%, var(--accent-nature));
		background:
			radial-gradient(ellipse 70% 90% at 50% 130%, color-mix(in srgb, var(--accent) 5%, transparent), transparent 52%),
			linear-gradient(
				180deg,
				color-mix(in srgb, var(--joy) 6%, transparent),
				color-mix(in srgb, var(--accent-nature) 5%, transparent)
			);
		text-align: center;
		color: var(--muted);
		font-size: 0.88rem;
	}

	.site-footer p {
		margin: 0;
	}

	.site-footer a {
		color: var(--accent);
	}

	.prose :where(h1) {
		font-family: var(--font-display);
		font-weight: 800;
		line-height: 1.18;
		letter-spacing: -0.012em;
		text-rendering: optimizeLegibility;
	}
	.prose :where(h2) {
		font-family: var(--font-body);
		font-weight: 700;
		line-height: 1.28;
		color: var(--accent-nature);
		letter-spacing: -0.01em;
	}
	.prose :where(h3) {
		font-family: var(--font-body);
		font-weight: 600;
		line-height: 1.3;
		color: color-mix(in srgb, var(--accent) 85%, var(--fg));
	}
	.prose :where(p) {
		margin: 0 0 1em;
	}
	.prose :where(a) {
		color: var(--accent);
		font-weight: 500;
		text-decoration: underline;
		text-decoration-thickness: 0.08em;
		text-underline-offset: 0.2em;
		transition:
			color 0.15s ease,
			text-decoration-color 0.15s ease;
	}
	.prose :where(a):hover {
		color: color-mix(in srgb, var(--accent) 55%, var(--joy));
		text-decoration-color: var(--joy);
	}
	.prose :where(strong) {
		color: color-mix(in srgb, var(--fg) 70%, var(--accent));
		font-weight: 600;
	}
	.prose :where(blockquote) {
		margin: 1.25rem 0;
		padding: 0.85rem 1rem 0.85rem 1.1rem;
		border-left: 4px solid var(--accent-nature);
		border-radius: 0 0.65rem 0.65rem 0;
		background: linear-gradient(
			135deg,
			color-mix(in srgb, var(--accent-nature) 9%, transparent),
			color-mix(in srgb, var(--joy) 6%, transparent)
		);
		font-style: italic;
		color: var(--muted);
	}
	.prose :where(ul) {
		padding-left: 1.2rem;
	}
	.prose :where(ul > li::marker) {
		color: var(--accent-nature-soft);
	}
	.prose :where(ol > li::marker) {
		color: var(--joy);
		font-weight: 600;
	}
	.prose :where(img) {
		border-radius: 0.75rem;
		box-shadow:
			0 2px 12px color-mix(in srgb, var(--fg) 8%, transparent),
			0 0 0 1px color-mix(in srgb, var(--border) 80%, var(--accent-nature));
	}
	.prose :where(hr) {
		border: none;
		height: 2px;
		margin: 2rem 0;
		border-radius: 2px;
		background: linear-gradient(90deg, transparent, var(--accent-nature), var(--joy), var(--accent), transparent);
		opacity: 0.45;
	}
	.prose :where(code) {
		font-size: 0.92em;
		padding: 0.12em 0.35em;
		border-radius: 0.35rem;
		background: color-mix(in srgb, var(--accent-nature) 10%, var(--border));
		color: var(--fg);
	}
	.prose :where(pre code) {
		padding: 0;
		background: none;
	}
	.prose :where(pre) {
		padding: 1rem;
		border-radius: 0.65rem;
		border: 1px solid var(--border);
		background: color-mix(in srgb, var(--bg) 70%, var(--nav-bg));
		overflow-x: auto;
	}
</style>
