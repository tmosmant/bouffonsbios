---
import { NAV_HIGHLIGHT } from '../site-config';

interface Props {
	title: string;
	description?: string;
	/** Lien actif dans la barre principale */
	current?: 'highlight' | 'articles' | 'manifeste' | 'contact' | 'plan';
}

const { title, description = 'Bouffons Bios — association', current } = Astro.props;

const nav = [
	{ id: 'highlight' as const, href: NAV_HIGHLIGHT.href, label: NAV_HIGHLIGHT.label },
	{ id: 'articles' as const, href: '/articles/', label: 'Articles' },
	{ id: 'manifeste' as const, href: '/manifeste/', label: 'Manifeste' },
	{ id: 'contact' as const, href: '/contact/', label: 'Contact' },
	{ id: 'plan' as const, href: '/plan-dacces/', label: "Plan d'accès" },
];
---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		{description && <meta name="description" content={description} />}
		<title>{title}</title>
	</head>
	<body>
		<a href="#contenu" class="skip">Aller au contenu</a>
		<header class="site-head">
			<div class="site-brand">
				<a class="logo" href="/">Bouffons Bios</a>
			</div>
			<nav class="site-nav" aria-label="Navigation principale">
				<ul>
					{
						nav.map((item) => (
							<li>
								<a href={item.href} class:list={[{ active: current === item.id }]}>
									{item.label}
								</a>
							</li>
						))
					}
				</ul>
			</nav>
		</header>
		<main id="contenu" class="site-main">
			<slot />
		</main>
		<footer class="site-footer">
			<p>Association Bouffons Bios — <a href="/contact/">Contact</a></p>
		</footer>
	</body>
</html>

<style is:global>
	:root {
		color-scheme: light dark;
		--bg: #faf8f5;
		--fg: #1a1814;
		--accent: #6b3d2e;
		--accent-soft: #8b5a45;
		--muted: #5c5850;
		--border: #e0dbd4;
		--nav-bg: #f0ebe3;
		font-family:
			system-ui,
			-apple-system,
			'Segoe UI',
			Roboto,
			sans-serif;
		line-height: 1.6;
	}

	@media (prefers-color-scheme: dark) {
		:root {
			--bg: #141210;
			--fg: #f2ede6;
			--accent: #d4a574;
			--accent-soft: #c9a882;
			--muted: #a39e94;
			--border: #2e2a26;
			--nav-bg: #1c1a17;
		}
	}

	* {
		box-sizing: border-box;
	}

	html {
		background: var(--bg);
		color: var(--fg);
	}

	body {
		margin: 0;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
	}

	.skip {
		position: absolute;
		left: -9999px;
	}
	.skip:focus {
		left: 1rem;
		top: 1rem;
		z-index: 999;
		padding: 0.5rem 1rem;
		background: var(--accent);
		color: var(--bg);
	}

	.site-head {
		border-bottom: 1px solid var(--border);
		background: var(--bg);
	}

	.site-brand {
		padding: 1rem 1.25rem 0.6rem;
	}

	.logo {
		font-weight: 700;
		font-size: 1.2rem;
		color: var(--fg);
		text-decoration: none;
		letter-spacing: -0.02em;
	}
	.logo:hover {
		color: var(--accent);
	}

	.site-nav {
		background: var(--nav-bg);
		border-top: 1px solid var(--border);
		overflow-x: auto;
		-webkit-overflow-scrolling: touch;
	}

	.site-nav ul {
		display: flex;
		flex-wrap: nowrap;
		gap: 0;
		margin: 0;
		padding: 0 0.5rem;
		list-style: none;
		min-height: 2.85rem;
		align-items: stretch;
	}

	.site-nav li {
		display: flex;
		flex-shrink: 0;
	}

	.site-nav a {
		display: flex;
		align-items: center;
		padding: 0.65rem 0.9rem;
		color: var(--muted);
		text-decoration: none;
		font-size: 0.9rem;
		font-weight: 500;
		border-bottom: 2px solid transparent;
		white-space: nowrap;
		max-width: 16rem;
		line-height: 1.25;
	}

	.site-nav a:hover {
		color: var(--accent);
		background: color-mix(in srgb, var(--accent) 6%, transparent);
	}

	.site-nav a.active {
		color: var(--accent);
		border-bottom-color: var(--accent);
	}

	.site-main {
		flex: 1;
		width: 100%;
		max-width: 46rem;
		margin: 0 auto;
		padding: 2rem 1.5rem 3rem;
	}

	.site-footer {
		padding: 1.25rem 1.5rem;
		border-top: 1px solid var(--border);
		text-align: center;
		color: var(--muted);
		font-size: 0.88rem;
	}

	.site-footer p {
		margin: 0;
	}

	.site-footer a {
		color: var(--accent);
	}

	.prose :where(h1, h2, h3) {
		line-height: 1.25;
	}
	.prose :where(p) {
		margin: 0 0 1em;
	}
	.prose :where(a) {
		color: var(--accent);
	}
</style>
