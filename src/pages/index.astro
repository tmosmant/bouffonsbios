---
import Layout from '../layouts/Layout.astro';
import { PRESSE_ITEMS } from '../data/presse';
---

<Layout title="Bouffons Bios" current="highlight">
	<section id="marche" class="hero" aria-labelledby="marche-title">
		<h1 id="marche-title" class="hero-title">
			Samedi 9 mai 2026 — 21<sup>e</sup> marché des vins bio
		</h1>
		<p class="hero-tagline"><em>Le grand retour du Développement buvable&nbsp;!</em></p>

		<p class="hero-lead">
			<strong
				><a href="/articles/vignerons-participants-en-2026/">Liste évolutive des participants</a></strong
			>
		</p>

		<div class="hero-block">
			<p>
				<strong>50+ vignerons passionnés</strong> venus des quatre coins de France, mais aussi de plus loin avec
				nos invités d’<strong>Italie</strong> et de <strong>Géorgie</strong> (le berceau du vin&nbsp;!).
			</p>
			<p>Des quilles vivantes, du bio, du biodynamique, du naturel et de la bonne humeur à chaque stand.</p>
		</div>

		<div class="hero-infos">
			<p>
				<strong>Quand&nbsp;?</strong> samedi 9 mai 2026, 10h00–19h00<br />
				<strong>Où&nbsp;?</strong> sous la halle du marché de la Croix de Chavaux,<br />
				rue de Paris, 93100 Montreuil.<br />
				<strong>Métro&nbsp;:</strong> Croix de Chavaux (ligne 9). <strong>Bus&nbsp;:</strong> 102, 115, 122, 127,
				202
			</p>
			<p>Entrée&nbsp;: 5&nbsp;€, verre gravé offert.</p>
			<p class="legal">
				<em>Si l’abus d’alcool est dangereux pour la santé, le vin bio est une fête pour l’esprit&nbsp;!</em>
			</p>
		</div>

		<p class="org">
			Organisé par l’association Bouffons Bios — <a href="/contact/">Contact</a> : Daniel Mosmant,
			<a href="tel:+33676692598">+33&nbsp;6&nbsp;76&nbsp;69&nbsp;25&nbsp;98</a>
		</p>

		<p class="cta">
			<a class="btn" href="/articles/">Tous les articles</a>
			<a class="btn btn-secondary" href="/plan-dacces/">Plan d’accès</a>
		</p>
	</section>

	<section class="presse" aria-labelledby="presse-title">
		<h2 id="presse-title">Ils parlent de nous&nbsp;!</h2>
		<p class="presse-intro">
			Articles, blogs et agendas qui ont relayé le marché ou l’association — merci à elles et eux.
		</p>
		<ul class="presse-list">
			{
				PRESSE_ITEMS.map((item) => (
					<li>
						<a href={item.href} target="_blank" rel="noopener noreferrer">
							<span class="presse-source">{item.source}</span>
							<span class="presse-title">{item.title}</span>
						</a>
					</li>
				))
			}
		</ul>
	</section>
</Layout>

<style>
	.hero {
		padding-bottom: 1rem;
	}
	.hero-title {
		font-size: clamp(1.35rem, 4vw, 1.85rem);
		margin: 0 0 0.5rem;
		line-height: 1.2;
		font-weight: 700;
	}
	.hero-tagline {
		font-size: 1.1rem;
		margin: 0 0 1.25rem;
		color: var(--accent, #6b3d2e);
	}
	.hero-lead {
		margin: 0 0 1.25rem;
		font-size: 1.05rem;
	}
	.hero-block p,
	.hero-infos p {
		margin: 0 0 1rem;
		color: var(--muted, #5c5850);
	}
	.hero-block p strong,
	.hero-infos p strong {
		color: var(--fg, #1a1814);
	}
	@media (prefers-color-scheme: dark) {
		.hero-block p strong,
		.hero-infos p strong {
			color: var(--fg, #f2ede6);
		}
	}
	.legal {
		font-size: 0.95rem;
	}
	.org {
		margin-top: 1.5rem;
		font-size: 0.95rem;
		color: var(--muted, #5c5850);
	}
	.org a {
		color: var(--accent, #6b3d2e);
	}
	.cta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.65rem;
		margin-top: 1.75rem;
	}
	.btn {
		display: inline-block;
		padding: 0.55rem 1rem;
		background: var(--accent, #6b3d2e);
		color: var(--bg, #faf8f5);
		text-decoration: none;
		border-radius: 6px;
		font-weight: 600;
		font-size: 0.95rem;
	}
	.btn-secondary {
		background: transparent;
		color: var(--accent, #6b3d2e);
		border: 2px solid var(--accent, #6b3d2e);
	}
	@media (prefers-color-scheme: dark) {
		.btn {
			color: #141210;
		}
		.btn-secondary {
			color: var(--accent, #d4a574);
			border-color: var(--accent, #d4a574);
		}
	}

	.presse {
		margin-top: 2.75rem;
		padding-top: 2rem;
		border-top: 1px solid var(--border, #e0dbd4);
	}
	.presse h2 {
		margin: 0 0 0.5rem;
		font-size: 1.25rem;
		font-weight: 700;
	}
	.presse-intro {
		margin: 0 0 1.25rem;
		font-size: 0.92rem;
		color: var(--muted, #5c5850);
	}
	.presse-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.65rem;
	}
	.presse-list li a {
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
		padding: 0.65rem 0.75rem;
		border-radius: 8px;
		border: 1px solid var(--border, #e0dbd4);
		text-decoration: none;
		color: inherit;
		transition:
			background 0.15s ease,
			border-color 0.15s ease;
	}
	.presse-list li a:hover {
		background: color-mix(in srgb, var(--accent) 8%, transparent);
		border-color: color-mix(in srgb, var(--accent) 35%, var(--border));
	}
	.presse-source {
		font-size: 0.72rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--accent, #6b3d2e);
	}
	.presse-title {
		font-size: 0.95rem;
		line-height: 1.35;
		color: var(--fg, #1a1814);
	}
</style>
