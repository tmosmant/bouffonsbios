---
import { getEntry } from 'astro:content';
import { marked } from 'marked';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import SiteFlash from '../components/SiteFlash.astro';
import TransitBadges from '../components/TransitBadges.astro';
import Layout from '../layouts/Layout.astro';

const homeEntry = await getEntry('home', 'hero');
if (!homeEntry) {
	throw new Error('Fichier src/content/home.json introuvable ou clé « hero » manquante.');
}
const h = homeEntry.data;

const presseEntry = await getEntry('presse', 'block');
if (!presseEntry) {
	throw new Error('Fichier src/content/presse.json introuvable ou clé "block" manquante.');
}
const presse = presseEntry.data;

const flashEntry = await getEntry('flash', 'flash');
if (!flashEntry) {
	throw new Error('Fichier src/content/flash.json introuvable ou clé « flash » manquante.');
}
const flash = flashEntry.data;
const showFlashHomeOnly =
	flash.enabled && !flash.showOnAllPages && flash.bodyMarkdown.trim().length > 0;

const taglineHtml = marked.parseInline(h.taglineMarkdown, { async: false }) as string;
const programHtml = marked(h.programMarkdown, { async: false, breaks: true }) as string;
const legalHtml = marked.parseInline(h.legalMarkdown, { async: false }) as string;
const orgHtml = marked.parseInline(h.orgMarkdown, { async: false }) as string;

/** Partage réseaux sociaux : champs CMS (og*) ou repli à partir du héros. */
const openGraphTitleFallback = `${h.titleLine1} — ${h.dateLabel} · ${h.titleLine2}`;
const openGraphDescriptionFallback =
	`${h.dateLabel}, ${h.hours} — sous la halle du marché, Croix de Chavaux (Montreuil). ` +
	`Plus de cinquante vignerons en agriculture biologique, biodynamie et vins nature, ` +
	`de la France à l’Italie et la Géorgie. Entrée 5 €, verre gravé offert. ` +
	`Le rendez-vous convivial du vin vivant à l’est de Paris — ${h.badge}, par l’association Bouffons Bios.`;
const openGraphTitle = h.ogTitle?.trim() || openGraphTitleFallback;
const openGraphDescription = h.ogDescription?.trim() || openGraphDescriptionFallback;
const openGraphImageRaw = h.ogImage?.trim() ?? '';
const openGraphImage =
	openGraphImageRaw !== ''
		? openGraphImageRaw.startsWith('/')
			? openGraphImageRaw
			: `/${openGraphImageRaw}`
		: '/uploads/affiche-site-2021.jpg';
const openGraphImageAltFallback = `Affiche — ${h.titleLine1}, ${h.titleLine2} (${h.dateLabel})`;
const openGraphImageAlt = h.ogImageAlt?.trim() || openGraphImageAltFallback;

/** Ligne 2 sur la même ligne que la 1 si elle commence par un tiret long (ex. « — verre offert »). */
function infoLine2SameRow(line2: string | undefined): boolean {
	if (!line2?.trim()) return false;
	const s = line2.trimStart();
	const c = s.codePointAt(0);
	return c === 0x2014 || c === 0x2013 || /^-\s/.test(s);
}
---

<Layout
	title={h.metaTitle}
	description={h.metaDescription}
	current="highlight"
	mainClass="site-main--home"
	openGraph={{
		title: openGraphTitle,
		description: openGraphDescription,
		image: openGraphImage,
		imageAlt: openGraphImageAlt,
		type: 'website',
	}}
>
	<link rel="preload" as="image" href="/uploads/bandeau.jpg" slot="head" />
	{
		showFlashHomeOnly && (
			<div class="home-flash-banner">
				<SiteFlash
					title={flash.title}
					bodyMarkdown={flash.bodyMarkdown}
					linkLabel={flash.linkLabel}
					linkHref={flash.linkHref}
					placement="home"
				/>
			</div>
		)
	}
	<div class="home-columns">
		<div class="home-main">
		<section class="hero" aria-labelledby="accueil-hero-title">
		<div class="hero-stack">
			<figure class="hero-banner">
				<img
					class="hero-banner-img"
					src="/uploads/bandeau.jpg"
					alt="Bannière illustrée — ambiance marché de vins bio Bouffons Bios"
					width="1696"
					height="624"
					loading="eager"
					decoding="async"
				/>
			</figure>
			<div class="hero-surface">
			<div class="hero-top">
				<span class="hero-badge">{h.badge}</span>
				<span class="hero-date" aria-hidden="true">·</span>
				<time class="hero-date" datetime={h.dateDatetime}>{h.dateLabel}</time>
				<span class="hero-hours">{h.hours}</span>
			</div>

			<h1 id="accueil-hero-title" class="hero-display">
				<span class="hero-display-line">{h.titleLine1}</span>
				<span class="hero-display-sub">{h.titleLine2}</span>
			</h1>

			<p class="hero-tagline markdown-inline" set:html={taglineHtml} />

			<a class="hero-participants" href={h.participantsHref}>
				<span class="hero-participants-icon" aria-hidden="true">{h.participantsIcon}</span>
				<span class="hero-participants-text">
					<strong>{h.participantsTitle}</strong>
					<span class="hero-participants-hint">{h.participantsHint}</span>
				</span>
				<span class="hero-participants-arrow" aria-hidden="true">→</span>
			</a>

			<div class="hero-grid">
				<div class="hero-panel hero-panel--prose markdown-inline">
					<h2 class="hero-panel-title">{h.programTitle}</h2>
					<div set:html={programHtml} />
				</div>
				<div class="hero-panel hero-panel--infos">
					<h2 class="hero-panel-title">{h.infosTitle}</h2>
					<dl class="hero-dl">
						{
							h.infoRows.map((row) => (
								<div>
									<dt>{row.term}</dt>
									<dd>
										{row.term === 'Accès' ? (
											<TransitBadges />
										) : (
											<>
												{row.line1}
												{row.line2 ? (
													infoLine2SameRow(row.line2) ? (
														<>
															{' '}
															<span class="hero-dd-muted">{row.line2}</span>
														</>
													) : (
														<>
															<br />
															<span class="hero-dd-muted">{row.line2}</span>
														</>
													)
												) : null}
											</>
										)}
									</dd>
								</div>
							))
						}
					</dl>
				</div>
			</div>

			<p class="hero-legal markdown-inline" set:html={legalHtml} />

			<p class="hero-org markdown-inline" set:html={orgHtml} />

			<div class="hero-cta">
				<a class="btn btn-primary" href={h.ctaPrimaryHref}>{h.ctaPrimaryLabel}</a>
				<a class="btn btn-ghost" href={h.ctaSecondaryHref}>{h.ctaSecondaryLabel}</a>
			</div>
			</div>
		</div>
	</section>
		</div>

		<div class="home-sidebar">
		<NewsletterSignup source="accueil" />
		<aside class="presse presse-aside" aria-labelledby="presse-title">
			<h2 id="presse-title">{presse.heading}</h2>
			<p class="presse-intro">{presse.intro}</p>
			{
				presse.items.length > 0 && (
					<ul class="presse-list">
						{presse.items.map((item) => (
							<li>
								<a href={item.href} target="_blank" rel="noopener noreferrer">
									<span class="presse-source">{item.source}</span>
									<span class="presse-title">{item.title}</span>
								</a>
							</li>
						))}
					</ul>
				)
			}
		</aside>
		</div>
	</div>
</Layout>

<style>
	.home-flash-banner {
		width: 100%;
		min-width: 0;
	}

	.home-columns {
		display: grid;
		gap: 1.75rem;
		align-items: start;
		min-width: 0;
		width: 100%;
	}

	@media (min-width: 56rem) {
		.home-columns {
			grid-template-columns: minmax(0, 1fr) minmax(15.25rem, 18rem);
			column-gap: 2rem;
		}
	}

	.home-main {
		min-width: 0;
	}

	.home-sidebar {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		min-width: 0;
	}

	@media (min-width: 56rem) {
		.home-sidebar {
			position: sticky;
			top: 1.25rem;
		}
	}

	.hero {
		--hero-font: 'Source Sans 3', system-ui, sans-serif;
		--hero-display: 'Fraunces', Georgia, 'Times New Roman', serif;
		font-family: var(--hero-font);
		margin: 0 -0.25rem;
		padding-bottom: 0.5rem;
	}

	/* Bannière héritée + carte héros = un seul bloc visuel */
	.hero-stack {
		position: relative;
		border-radius: 1.35rem;
		overflow: hidden;
		border: 1px solid color-mix(in srgb, var(--border) 70%, var(--accent-nature));
		box-shadow:
			0 1px 2px color-mix(in srgb, var(--fg) 5%, transparent),
			0 14px 44px -16px color-mix(in srgb, var(--accent) 28%, transparent),
			0 0 0 1px color-mix(in srgb, var(--joy) 12%, transparent) inset;
	}

	.hero-banner {
		position: relative;
		margin: 0;
		padding: 0;
		border: 0;
		line-height: 0;
	}

	.hero-banner-img {
		display: block;
		width: 100%;
		height: clamp(7.25rem, 28vw, 12.75rem);
		object-fit: cover;
		object-position: 50% 42%;
	}

	.hero-banner::after {
		content: '';
		position: absolute;
		inset: 0;
		pointer-events: none;
		background: linear-gradient(
			180deg,
			transparent 40%,
			color-mix(in srgb, var(--bg) 22%, transparent) 88%,
			color-mix(in srgb, var(--bg) 55%, transparent) 100%
		);
	}

	.hero-surface {
		position: relative;
		padding: clamp(1.35rem, 4vw, 2rem) clamp(1.1rem, 3vw, 1.75rem);
		border-radius: 0;
		border: none;
		border-top: 1px solid color-mix(in srgb, var(--border) 65%, var(--joy));
		background:
			radial-gradient(ellipse 100% 72% at 108% -12%, color-mix(in srgb, var(--joy) 26%, transparent) 0%, transparent 54%),
			radial-gradient(ellipse 88% 58% at -8% 108%, color-mix(in srgb, var(--accent-nature) 22%, transparent) 0%, transparent 52%),
			radial-gradient(ellipse 42% 32% at 94% 90%, color-mix(in srgb, var(--accent) 18%, transparent) 0%, transparent 50%),
			radial-gradient(ellipse 36% 28% at 6% 6%, color-mix(in srgb, var(--accent) 14%, transparent) 0%, transparent 48%),
			radial-gradient(ellipse 48% 34% at 55% 0%, color-mix(in srgb, var(--joy-soft) 14%, transparent) 0%, transparent 44%),
			var(--bg, #f6f1e8);
		overflow: hidden;
	}

	.hero-surface::before {
		content: '';
		position: absolute;
		inset: 0;
		background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
		opacity: 0.7;
		pointer-events: none;
		border-radius: inherit;
	}

	/* Taches vin + formes feuille (ellipses) — au-dessus du fond, sous le grain */
	.hero-surface::after {
		content: '';
		position: absolute;
		inset: -25% -12%;
		pointer-events: none;
		border-radius: inherit;
		background:
			radial-gradient(ellipse 34% 24% at 76% 18%, color-mix(in srgb, var(--accent) 24%, transparent), transparent 68%),
			radial-gradient(ellipse 28% 18% at 14% 62%, color-mix(in srgb, var(--accent) 18%, transparent), transparent 62%),
			radial-gradient(ellipse 40% 26% at 92% 86%, color-mix(in srgb, var(--accent-soft) 22%, transparent), transparent 65%),
			radial-gradient(ellipse 24% 38% at 88% 28%, color-mix(in srgb, var(--accent-nature) 12%, transparent), transparent 58%),
			radial-gradient(ellipse 30% 46% at 12% 22%, color-mix(in srgb, var(--accent-nature) 10%, transparent), transparent 55%),
			radial-gradient(ellipse 18% 14% at 48% 48%, color-mix(in srgb, var(--accent) 10%, transparent), transparent 52%);
		opacity: 1;
		z-index: 0;
	}

	.hero-top,
	.hero-display,
	.hero-tagline,
	.hero-participants,
	.hero-grid,
	.hero-legal,
	.hero-org,
	.hero-cta {
		position: relative;
		z-index: 1;
	}

	.hero-top {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.35rem 0.65rem;
		margin-bottom: 1rem;
		font-size: 0.8rem;
		font-weight: 600;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--accent-nature, #35624a);
	}

	.hero-badge {
		display: inline-flex;
		align-items: center;
		padding: 0.22rem 0.6rem;
		border-radius: 999px;
		background: linear-gradient(
			135deg,
			color-mix(in srgb, var(--accent-nature) 16%, transparent),
			color-mix(in srgb, var(--joy) 14%, transparent)
		);
		border: 1px solid color-mix(in srgb, var(--accent-nature) 35%, var(--joy));
		color: var(--accent, #8f2d4a);
	}

	.hero-date {
		font-weight: 500;
		letter-spacing: 0.02em;
		color: var(--fg, #1a1814);
		text-transform: none;
	}

	.hero-hours {
		opacity: 0.75;
		font-weight: 500;
	}

	.hero-display {
		font-family: var(--hero-display);
		font-weight: 800;
		font-size: clamp(1.875rem, 6vw, 2.625rem);
		line-height: 1.08;
		letter-spacing: -0.015em;
		margin: 0 0 0.65rem;
		color: var(--fg, #1a1814);
		text-rendering: optimizeLegibility;
		text-shadow: 0 1px 0 color-mix(in srgb, var(--bg) 65%, transparent);
	}

	.hero-display-line {
		display: block;
	}

	.hero-display-sub {
		display: block;
		margin-top: 0.35rem;
		font-family: var(--hero-font);
		font-size: clamp(0.95rem, 2.8vw, 1.1rem);
		font-weight: 600;
		letter-spacing: 0.01em;
		color: var(--muted, #5c5850);
	}

	.hero-tagline {
		font-size: 1.08rem;
		line-height: 1.45;
		margin: 0 0 1.25rem;
		color: var(--muted, #5c5850);
		max-width: 36ch;
	}

	.hero-tagline.markdown-inline :global(em) {
		color: var(--accent, #8f2d4a);
		font-style: italic;
		font-weight: 500;
	}

	.hero-participants {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		padding: 0.85rem 1rem;
		margin-bottom: 1.5rem;
		border-radius: 0.95rem;
		text-decoration: none;
		color: inherit;
		background: color-mix(in srgb, var(--fg) 4%, transparent);
		border: 1px solid var(--border, #e0dbd4);
		transition:
			transform 0.18s ease,
			border-color 0.18s ease,
			background 0.18s ease;
	}

	.hero-participants:hover {
		border-color: color-mix(in srgb, var(--accent) 45%, var(--border));
		background: color-mix(in srgb, var(--accent) 8%, transparent);
		transform: translateY(-1px);
	}

	.hero-participants-icon {
		font-size: 1.15rem;
		line-height: 1;
		background: linear-gradient(145deg, var(--accent-nature, #35624a), var(--joy, #c9892e));
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
		filter: drop-shadow(0 1px 0 color-mix(in srgb, var(--fg) 8%, transparent));
	}

	.hero-participants-text {
		flex: 1;
		min-width: 0;
		display: flex;
		flex-direction: column;
		gap: 0.1rem;
	}

	.hero-participants-text strong {
		font-size: 1rem;
		font-weight: 600;
		color: var(--fg, #1a1814);
	}

	.hero-participants-hint {
		font-size: 0.85rem;
		color: var(--muted, #5c5850);
	}

	.hero-participants-arrow {
		font-size: 1.15rem;
		color: var(--joy, #c9892e);
		transition: transform 0.18s ease;
	}

	.hero-participants:hover .hero-participants-arrow {
		transform: translateX(3px);
	}

	.hero-grid {
		display: grid;
		gap: 1rem;
		margin-bottom: 1.25rem;
	}

	@media (min-width: 36rem) {
		.hero-grid {
			grid-template-columns: 1fr 1fr;
			gap: 1rem 1.25rem;
		}
	}

	.hero-panel {
		padding: 1rem 1.05rem;
		border-radius: 0.85rem;
		background: color-mix(in srgb, var(--bg) 70%, transparent);
		backdrop-filter: blur(8px);
		border: 1px solid color-mix(in srgb, var(--border) 90%, var(--accent));
	}

	.hero-panel-title {
		font-size: 0.72rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		margin: 0 0 0.65rem;
		background: linear-gradient(90deg, var(--accent-nature, #35624a), var(--accent, #8f2d4a));
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
	}

	.hero-panel--prose.markdown-inline :global(p) {
		margin: 0;
		font-size: 0.95rem;
		line-height: 1.55;
		color: var(--muted, #5c5850);
	}

	.hero-panel--prose.markdown-inline :global(strong) {
		color: var(--fg, #1a1814);
	}

	.hero-dl {
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.hero-dl > div {
		margin: 0;
	}

	.hero-dl dt {
		font-size: 0.7rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--muted, #5c5850);
		margin-bottom: 0.2rem;
	}

	.hero-dl dd {
		margin: 0;
		font-size: 0.9rem;
		line-height: 1.45;
		color: var(--fg, #1a1814);
	}

	.hero-dd-muted {
		font-size: 0.88rem;
		color: var(--muted, #5c5850);
	}

	.hero-legal {
		font-size: 0.82rem;
		line-height: 1.4;
		color: var(--muted, #5c5850);
		margin: 0 0 1rem;
	}

	.hero-org {
		font-size: 0.88rem;
		line-height: 1.5;
		color: var(--muted, #5c5850);
		margin: 0 0 1.25rem;
	}

	.hero-org.markdown-inline :global(a) {
		color: var(--accent, #6b3d2e);
		font-weight: 500;
		text-decoration: none;
	}
	.hero-org.markdown-inline :global(a:hover) {
		text-decoration: underline;
	}

	.hero-cta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.62rem 1.15rem;
		border-radius: 0.65rem;
		font-size: 0.92rem;
		font-weight: 600;
		text-decoration: none;
		transition:
			transform 0.15s ease,
			box-shadow 0.15s ease,
			background 0.15s ease;
	}

	.btn-primary {
		background: linear-gradient(145deg, var(--accent, #8f2d4a) 0%, color-mix(in srgb, var(--accent) 75%, #4a1020) 100%);
		color: #fffef9;
		box-shadow:
			0 2px 14px color-mix(in srgb, var(--accent) 32%, transparent),
			0 0 0 1px color-mix(in srgb, var(--joy) 35%, transparent) inset;
	}
	.btn-primary:hover {
		transform: translateY(-2px);
		box-shadow:
			0 6px 22px color-mix(in srgb, var(--accent) 38%, transparent),
			0 0 0 1px color-mix(in srgb, var(--joy-soft) 50%, transparent) inset;
	}

	.btn-ghost {
		background: color-mix(in srgb, var(--joy) 8%, transparent);
		color: var(--accent-nature, #35624a);
		border: 1.5px solid color-mix(in srgb, var(--accent-nature) 40%, var(--border));
	}
	.btn-ghost:hover {
		background: linear-gradient(
			135deg,
			color-mix(in srgb, var(--accent-nature) 14%, transparent),
			color-mix(in srgb, var(--joy) 12%, transparent)
		);
		border-color: var(--accent-nature, #35624a);
	}

	.presse-aside {
		margin: 0;
		padding: 1.1rem 1rem 1.15rem;
		border-radius: 1.05rem;
		border: 1px solid color-mix(in srgb, var(--border) 72%, var(--accent-nature));
		background: linear-gradient(
			165deg,
			color-mix(in srgb, var(--joy) 10%, var(--bg)),
			color-mix(in srgb, var(--accent-nature) 7%, var(--bg)) 55%,
			var(--bg)
		);
		box-shadow:
			0 1px 0 color-mix(in srgb, var(--joy) 12%, transparent) inset,
			0 8px 28px -14px color-mix(in srgb, var(--accent) 22%, transparent);
	}


	.presse-aside h2 {
		font-family: var(--font-display, 'Fraunces', Georgia, serif);
		margin: 0 0 0.45rem;
		font-size: 1.05rem;
		font-weight: 800;
		line-height: 1.2;
		letter-spacing: -0.01em;
		color: var(--accent-nature, #35624a);
		text-rendering: optimizeLegibility;
	}

	.presse-intro {
		margin: 0 0 1rem;
		font-size: 0.82rem;
		line-height: 1.45;
		color: var(--muted, #5c5850);
	}

	.presse-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.presse-list li a {
		display: flex;
		flex-direction: column;
		gap: 0.12rem;
		padding: 0.55rem 0.65rem;
