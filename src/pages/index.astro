---
import { getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const presseEntry = await getEntry('presse', 'block');
if (!presseEntry) {
	throw new Error('Fichier src/content/presse.json introuvable ou clé "block" manquante.');
}
const presse = presseEntry.data;
---

<Layout title="Bouffons Bios" current="highlight" mainClass="site-main--home">
	<div class="home-main">
		<section class="hero" aria-labelledby="accueil-hero-title">
		<div class="hero-surface">
			<div class="hero-top">
				<span class="hero-badge">21ᵉ édition</span>
				<span class="hero-date" aria-hidden="true">·</span>
				<time class="hero-date" datetime="2026-05-09">Samedi 9 mai 2026</time>
				<span class="hero-hours">10h–19h</span>
			</div>

			<h1 id="accueil-hero-title" class="hero-display">
				<span class="hero-display-line">Marché des vins bio</span>
				<span class="hero-display-sub">Montreuil · Croix de Chavaux</span>
			</h1>

			<p class="hero-tagline">Le grand retour du <em>Développement buvable</em></p>

			<a class="hero-participants" href="/articles/vignerons-participants-en-2026/">
				<span class="hero-participants-icon" aria-hidden="true">◇</span>
				<span class="hero-participants-text">
					<strong>Participants 2026</strong>
					<span class="hero-participants-hint">Liste évolutive des vignerons</span>
				</span>
				<span class="hero-participants-arrow" aria-hidden="true">→</span>
			</a>

			<div class="hero-grid">
				<div class="hero-panel hero-panel--prose">
					<h2 class="hero-panel-title">Au programme</h2>
					<p>
						<strong>50+ vignerons</strong> venus de France, d’<strong>Italie</strong> et de
						<strong>Géorgie</strong> — bio, biodynamique, naturel et convivialité à chaque stand.
					</p>
				</div>
				<div class="hero-panel hero-panel--infos">
					<h2 class="hero-panel-title">Infos pratiques</h2>
					<dl class="hero-dl">
						<div>
							<dt>Lieu</dt>
							<dd>
								Halle du marché, Croix de Chavaux<br />
								<span class="hero-dd-muted">rue de Paris, 93100 Montreuil</span>
							</dd>
						</div>
						<div>
							<dt>Accès</dt>
							<dd>
								Métro ligne 9 · Croix de Chavaux<br />
								<span class="hero-dd-muted">Bus 102, 115, 122, 127, 202</span>
							</dd>
						</div>
						<div>
							<dt>Entrée</dt>
							<dd>5&nbsp;€ <span class="hero-dd-muted">— verre gravé offert</span></dd>
						</div>
					</dl>
				</div>
			</div>

			<p class="hero-legal">
				<em>Si l’abus d’alcool est dangereux pour la santé, le vin bio est une fête pour l’esprit.</em>
			</p>

			<p class="hero-org">
				Organisé par l’association Bouffons Bios ·
				<a href="/contact/">Contact</a>
				· Daniel Mosmant
				<a href="tel:+33676692598">06&nbsp;76&nbsp;69&nbsp;25&nbsp;98</a>
			</p>

			<div class="hero-cta">
				<a class="btn btn-primary" href="/articles/">Tous les articles</a>
				<a class="btn btn-ghost" href="/plan-dacces/">Plan d’accès</a>
			</div>
		</div>
	</section>
	</div>

	<aside class="presse presse-aside" aria-labelledby="presse-title">
		<h2 id="presse-title">{presse.heading}</h2>
		<p class="presse-intro">{presse.intro}</p>
		{
			presse.items.length > 0 && (
				<ul class="presse-list">
					{presse.items.map((item) => (
						<li>
							<a href={item.href} target="_blank" rel="noopener noreferrer">
								<span class="presse-source">{item.source}</span>
								<span class="presse-title">{item.title}</span>
							</a>
						</li>
					))}
				</ul>
			)
		}
	</aside>
</Layout>

<style>
	.home-main {
		min-width: 0;
	}

	.hero {
		--hero-font: 'Source Sans 3', system-ui, sans-serif;
		--hero-display: 'Fraunces', Georgia, 'Times New Roman', serif;
		font-family: var(--hero-font);
		margin: 0 -0.25rem;
		padding-bottom: 0.5rem;
	}

	.hero-surface {
		position: relative;
		padding: clamp(1.35rem, 4vw, 2rem) clamp(1.1rem, 3vw, 1.75rem);
		border-radius: 1.35rem;
		background:
			radial-gradient(120% 85% at 100% -5%, color-mix(in srgb, var(--joy) 22%, transparent) 0%, transparent 50%),
			radial-gradient(100% 70% at 0% 100%, color-mix(in srgb, var(--accent-nature) 18%, transparent) 0%, transparent 52%),
			radial-gradient(80% 60% at 85% 90%, color-mix(in srgb, var(--accent) 12%, transparent) 0%, transparent 45%),
			var(--bg, #f6f1e8);
		border: 1px solid color-mix(in srgb, var(--border) 70%, var(--accent-nature));
		box-shadow:
			0 1px 2px color-mix(in srgb, var(--fg) 5%, transparent),
			0 14px 44px -16px color-mix(in srgb, var(--accent) 28%, transparent),
			0 0 0 1px color-mix(in srgb, var(--joy) 12%, transparent) inset;
		overflow: hidden;
	}

	.hero-surface::before {
		content: '';
		position: absolute;
		inset: 0;
		background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
		opacity: 0.7;
		pointer-events: none;
		border-radius: inherit;
	}

	.hero-top,
	.hero-display,
	.hero-tagline,
	.hero-participants,
	.hero-grid,
	.hero-legal,
	.hero-org,
	.hero-cta {
		position: relative;
		z-index: 1;
	}

	.hero-top {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.35rem 0.65rem;
		margin-bottom: 1rem;
		font-size: 0.8rem;
		font-weight: 600;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--accent-nature, #35624a);
	}

	.hero-badge {
		display: inline-flex;
		align-items: center;
		padding: 0.22rem 0.6rem;
		border-radius: 999px;
		background: linear-gradient(
			135deg,
			color-mix(in srgb, var(--accent-nature) 16%, transparent),
			color-mix(in srgb, var(--joy) 14%, transparent)
		);
		border: 1px solid color-mix(in srgb, var(--accent-nature) 35%, var(--joy));
		color: var(--accent, #8f2d4a);
	}

	.hero-date {
		font-weight: 500;
		letter-spacing: 0.02em;
		color: var(--fg, #1a1814);
		text-transform: none;
	}

	.hero-hours {
		opacity: 0.75;
		font-weight: 500;
	}

	.hero-display {
		font-family: var(--hero-display);
		font-weight: 800;
		font-size: clamp(1.875rem, 6vw, 2.625rem);
		line-height: 1.08;
		letter-spacing: -0.018em;
		margin: 0 0 0.65rem;
		color: var(--fg, #1a1814);
		text-rendering: optimizeLegibility;
	}

	.hero-display-line {
		display: block;
	}

	.hero-display-sub {
		display: block;
		margin-top: 0.35rem;
		font-family: var(--hero-font);
		font-size: clamp(0.95rem, 2.8vw, 1.1rem);
		font-weight: 600;
		letter-spacing: 0.01em;
		color: var(--muted, #5c5850);
	}

	.hero-tagline {
		font-size: 1.08rem;
		line-height: 1.45;
		margin: 0 0 1.25rem;
		color: var(--muted, #5c5850);
		max-width: 36ch;
	}

	.hero-tagline em {
		color: var(--accent, #8f2d4a);
		font-style: italic;
		font-weight: 500;
	}

	.hero-participants {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		padding: 0.85rem 1rem;
		margin-bottom: 1.5rem;
		border-radius: 0.75rem;
		text-decoration: none;
		color: inherit;
		background: color-mix(in srgb, var(--fg) 4%, transparent);
		border: 1px solid var(--border, #e0dbd4);
		transition:
			transform 0.18s ease,
			border-color 0.18s ease,
			background 0.18s ease;
	}

	.hero-participants:hover {
		border-color: color-mix(in srgb, var(--accent) 45%, var(--border));
		background: color-mix(in srgb, var(--accent) 8%, transparent);
		transform: translateY(-1px);
	}

	.hero-participants-icon {
		font-size: 1.15rem;
		line-height: 1;
		background: linear-gradient(145deg, var(--accent-nature, #35624a), var(--joy, #c9892e));
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
		filter: drop-shadow(0 1px 0 color-mix(in srgb, var(--fg) 8%, transparent));
	}

	.hero-participants-text {
		flex: 1;
		min-width: 0;
		display: flex;
		flex-direction: column;
		gap: 0.1rem;
	}

	.hero-participants-text strong {
		font-size: 1rem;
		font-weight: 600;
		color: var(--fg, #1a1814);
	}

	.hero-participants-hint {
		font-size: 0.85rem;
		color: var(--muted, #5c5850);
	}

	.hero-participants-arrow {
		font-size: 1.15rem;
		color: var(--joy, #c9892e);
		transition: transform 0.18s ease;
	}

	.hero-participants:hover .hero-participants-arrow {
		transform: translateX(3px);
	}

	.hero-grid {
		display: grid;
		gap: 1rem;
		margin-bottom: 1.25rem;
	}

	@media (min-width: 36rem) {
		.hero-grid {
			grid-template-columns: 1fr 1fr;
			gap: 1rem 1.25rem;
		}
	}

	.hero-panel {
		padding: 1rem 1.05rem;
		border-radius: 0.85rem;
		background: color-mix(in srgb, var(--bg) 70%, transparent);
		backdrop-filter: blur(8px);
		border: 1px solid color-mix(in srgb, var(--border) 90%, var(--accent));
	}

	.hero-panel-title {
		font-size: 0.72rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		margin: 0 0 0.65rem;
		background: linear-gradient(90deg, var(--accent-nature, #35624a), var(--accent, #8f2d4a));
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
	}

	.hero-panel--prose p {
		margin: 0;
		font-size: 0.95rem;
		line-height: 1.55;
		color: var(--muted, #5c5850);
	}

	.hero-panel--prose strong {
		color: var(--fg, #1a1814);
	}

	.hero-dl {
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.hero-dl > div {
		margin: 0;
	}

	.hero-dl dt {
		font-size: 0.7rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--muted, #5c5850);
		margin-bottom: 0.2rem;
	}

	.hero-dl dd {
		margin: 0;
		font-size: 0.9rem;
		line-height: 1.45;
		color: var(--fg, #1a1814);
	}

	.hero-dd-muted {
		font-size: 0.88rem;
		color: var(--muted, #5c5850);
	}

	.hero-legal {
		font-size: 0.82rem;
		line-height: 1.4;
		color: var(--muted, #5c5850);
		margin: 0 0 1rem;
		max-width: 40ch;
	}

	.hero-org {
		font-size: 0.88rem;
		line-height: 1.5;
		color: var(--muted, #5c5850);
		margin: 0 0 1.25rem;
	}

	.hero-org a {
		color: var(--accent, #6b3d2e);
		font-weight: 500;
		text-decoration: none;
	}
	.hero-org a:hover {
		text-decoration: underline;
	}

	.hero-cta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.62rem 1.15rem;
		border-radius: 0.65rem;
		font-size: 0.92rem;
		font-weight: 600;
		text-decoration: none;
		transition:
			transform 0.15s ease,
			box-shadow 0.15s ease,
			background 0.15s ease;
	}

	.btn-primary {
		background: linear-gradient(145deg, var(--accent, #8f2d4a) 0%, color-mix(in srgb, var(--accent) 75%, #4a1020) 100%);
		color: #fffef9;
		box-shadow:
			0 2px 14px color-mix(in srgb, var(--accent) 32%, transparent),
			0 0 0 1px color-mix(in srgb, var(--joy) 35%, transparent) inset;
	}
	.btn-primary:hover {
		transform: translateY(-2px);
		box-shadow:
			0 6px 22px color-mix(in srgb, var(--accent) 38%, transparent),
			0 0 0 1px color-mix(in srgb, var(--joy-soft) 50%, transparent) inset;
	}

	.btn-ghost {
		background: color-mix(in srgb, var(--joy) 8%, transparent);
		color: var(--accent-nature, #35624a);
		border: 1.5px solid color-mix(in srgb, var(--accent-nature) 40%, var(--border));
	}
	.btn-ghost:hover {
		background: linear-gradient(
			135deg,
			color-mix(in srgb, var(--accent-nature) 14%, transparent),
			color-mix(in srgb, var(--joy) 12%, transparent)
		);
		border-color: var(--accent-nature, #35624a);
	}

	@media (prefers-color-scheme: dark) {
		.hero-surface {
			background:
				radial-gradient(120% 85% at 100% -5%, color-mix(in srgb, var(--joy) 18%, transparent) 0%, transparent 50%),
				radial-gradient(100% 70% at 0% 100%, color-mix(in srgb, var(--accent-nature) 16%, transparent) 0%, transparent 52%),
				radial-gradient(80% 60% at 85% 90%, color-mix(in srgb, var(--accent) 14%, transparent) 0%, transparent 45%),
				var(--bg, #151a16);
			box-shadow:
				0 1px 0 color-mix(in srgb, var(--fg) 8%, transparent),
				0 16px 48px -20px #000,
				0 0 0 1px color-mix(in srgb, var(--joy) 10%, transparent) inset;
		}
		.btn-primary {
			color: #1a120e;
		}
		.hero-panel-title {
			background: linear-gradient(90deg, var(--accent-nature), var(--joy-soft));
			-webkit-background-clip: text;
			background-clip: text;
			color: transparent;
		}
	}

	.presse-aside {
		margin: 0;
		padding: 1.1rem 1rem 1.15rem;
		border-radius: 1.05rem;
		border: 1px solid color-mix(in srgb, var(--border) 72%, var(--accent-nature));
		background: linear-gradient(
			165deg,
			color-mix(in srgb, var(--joy) 10%, var(--bg)),
			color-mix(in srgb, var(--accent-nature) 7%, var(--bg)) 55%,
			var(--bg)
		);
		box-shadow:
			0 1px 0 color-mix(in srgb, var(--joy) 12%, transparent) inset,
			0 8px 28px -14px color-mix(in srgb, var(--accent) 22%, transparent);
	}

	@media (min-width: 56rem) {
		.presse-aside {
			position: sticky;
			top: 1.25rem;
		}
	}

	@media (prefers-color-scheme: dark) {
		.presse-aside {
			background: linear-gradient(
				165deg,
				color-mix(in srgb, var(--joy) 8%, var(--bg)),
				color-mix(in srgb, var(--accent-nature) 10%, var(--bg)) 50%,
				var(--bg)
			);
			box-shadow:
				0 1px 0 color-mix(in srgb, var(--fg) 6%, transparent) inset,
				0 12px 36px -18px #000;
		}
	}

	.presse-aside h2 {
		font-family: var(--font-display, 'Fraunces', Georgia, serif);
		margin: 0 0 0.45rem;
		font-size: 1.05rem;
		font-weight: 800;
		line-height: 1.2;
		letter-spacing: -0.01em;
		color: var(--accent-nature, #35624a);
		text-rendering: optimizeLegibility;
	}

	.presse-intro {
		margin: 0 0 1rem;
		font-size: 0.82rem;
		line-height: 1.45;
		color: var(--muted, #5c5850);
	}

	.presse-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.presse-list li a {
		display: flex;
		flex-direction: column;
		gap: 0.12rem;
		padding: 0.55rem 0.65rem;
		border-radius: 0.65rem;
		border: 1px solid color-mix(in srgb, var(--border) 88%, var(--accent-nature));
		text-decoration: none;
		color: inherit;
		background: color-mix(in srgb, var(--bg) 55%, transparent);
		transition:
			background 0.18s ease,
			border-color 0.18s ease,
			transform 0.18s ease;
	}

	.presse-list li a:hover {
		background: linear-gradient(
			135deg,
			color-mix(in srgb, var(--accent-nature) 12%, transparent),
			color-mix(in srgb, var(--joy) 10%, transparent)
		);
		border-color: color-mix(in srgb, var(--accent-nature) 38%, var(--border));
		transform: translateY(-1px);
	}

	.presse-list .presse-source {
		font-size: 0.65rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--accent, #8f2d4a);
	}

	.presse-list .presse-title {
		font-size: 0.86rem;
		line-height: 1.32;
		color: var(--fg, #1a1814);
	}
</style>
