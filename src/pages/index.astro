---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Bouffons Bios">
	<section class="hero">
		<h1>Bouffons Bios</h1>
		<p class="lead">
			Site en cours de reconstruction — contenu géré via <strong>Decap CMS</strong> et hébergé sur
			<strong>Cloudflare Pages</strong>.
		</p>
		<p>
			<a class="btn" href="/articles">Voir les articles</a>
		</p>
	</section>
</Layout>

<style>
	.hero h1 {
		font-size: clamp(1.75rem, 4vw, 2.25rem);
		margin: 0 0 0.75em;
	}
	.lead {
		color: var(--muted, #5c5850);
		font-size: 1.05rem;
		margin: 0 0 1.5rem;
		max-width: 36ch;
	}
	.btn {
		display: inline-block;
		padding: 0.6rem 1.1rem;
		background: var(--accent, #5c3d2e);
		color: var(--bg, #faf8f5);
		text-decoration: none;
		border-radius: 6px;
		font-weight: 600;
	}
	@media (prefers-color-scheme: dark) {
		.btn {
			color: #141210;
		}
	}
</style>
