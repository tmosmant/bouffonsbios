---
import Layout from '../layouts/Layout.astro';
import { getEnv } from 'astro/env/runtime';
import 'mapbox-gl/dist/mapbox-gl.css';

/** Rendu à la demande : le jeton Mapbox est lu depuis l’env Worker (dashboard / wrangler), pas seulement au build. */
export const prerender = false;

const MAPBOX_STYLE = 'mapbox://styles/tmosmant/cmniwegjm003z01sa181h9ma0';
const mapboxToken = (getEnv('PUBLIC_MAPBOX_ACCESS_TOKEN') ?? '').trim();
const hasMapboxToken = mapboxToken.length > 0;
---

<Layout title="Plan d'accès — Bouffons Bios" description="Marché de la Croix de Chavaux, Montreuil" current="plan">
	<article class="prose">
		<h1>Plan d’accès</h1>
		<p>
			<strong>Place du marché Croix de Chavaux</strong><br />
			93100 Montreuil<br />
			<strong>Métro&nbsp;:</strong> Croix de Chavaux (ligne 9)<br />
			<strong>Bus&nbsp;:</strong> 102, 115, 122, 127, 202
		</p>

		<div class="map-live">
			<div
				id="map-acces"
				class="map-acces-inner"
				role="region"
				aria-label="Carte Mapbox — Croix de Chavaux, métro, bus et accès marché"
				data-style={MAPBOX_STYLE}
				data-mapbox-token={mapboxToken}
			>
			</div>
			{!hasMapboxToken && (
				<p class="map-live-fallback map-live-fallback--token">
					Carte interactive&nbsp;: ajoutez <code>PUBLIC_MAPBOX_ACCESS_TOKEN</code> au Worker Cloudflare
					(variables) et dans un <code>.env</code> local pour le dev — voir README.
				</p>
			)}
			<p class="map-live-fallback map-live-fallback--osm">
				<a
					href="https://www.openstreetmap.org/#map=17/48.8582/2.4360"
					rel="noopener noreferrer"
				>
					Ouvrir la zone sur OpenStreetMap
				</a>
			</p>
		</div>
	</article>
</Layout>

<script>
	import mapboxgl from 'mapbox-gl';
	import transitFc from '../data/croix-chavaux-transit.json';

	const INTERACTIVE_LAYERS = ['transit-bus', 'transit-exit', 'transit-station', 'transit-venue'];

	const ICON_URLS: Record<string, string> = {
		'bb-metro': '/map-icons/metro.svg',
		'bb-bus': '/map-icons/bus.png',
		'bb-exit': '/map-icons/exit.png',
		'bb-venue': '/map-icons/venue.svg',
	};

	/** Taille d’affichage « logique » sur la carte (sources 500×500 / 800×800 redimensionnées). */
	const ICON_LOGICAL_PX: Record<string, { w: number; h: number }> = {
		'bb-metro': { w: 32, h: 32 },
		'bb-bus': { w: 32, h: 32 },
		'bb-exit': { w: 32, h: 32 },
		'bb-venue': { w: 36, h: 40 },
	};

	const ICON_PIXEL_RATIO = 2;

	/**
	 * Raster commun : SVG (fetch text → blob) ou PNG (fetch blob) → canvas @2x → ImageData pour Mapbox.
	 */
	async function addRasterIcon(map: mapboxgl.Map, id: string, path: string): Promise<void> {
		const logical = ICON_LOGICAL_PX[id];
		if (!logical) throw new Error(`Icône inconnue : ${id}`);

		const url = new URL(path, window.location.origin).href;
		const res = await fetch(url);
		if (!res.ok) throw new Error(`HTTP ${res.status} — ${path}`);

		const isSvg = path.endsWith('.svg');
		let objectUrl: string;
		if (isSvg) {
			const svgMarkup = await res.text();
			objectUrl = URL.createObjectURL(
				new Blob([svgMarkup], { type: 'image/svg+xml;charset=utf-8' }),
			);
		} else {
			objectUrl = URL.createObjectURL(await res.blob());
		}

		const img = new Image();
		try {
			await new Promise<void>((resolve, reject) => {
				img.onload = () => resolve();
				img.onerror = () =>
					reject(new Error(`Décode image impossible : ${path}`));
				img.src = objectUrl;
			});
		} finally {
			URL.revokeObjectURL(objectUrl);
		}

		const cw = logical.w * ICON_PIXEL_RATIO;
		const ch = logical.h * ICON_PIXEL_RATIO;
		const canvas = document.createElement('canvas');
		canvas.width = cw;
		canvas.height = ch;
		const ctx = canvas.getContext('2d', { willReadFrequently: true });
		if (!ctx) throw new Error('Canvas 2D indisponible');

		ctx.clearRect(0, 0, cw, ch);
		ctx.drawImage(img, 0, 0, cw, ch);

		const data = ctx.getImageData(0, 0, cw, ch);
		if (map.hasImage(id)) map.removeImage(id);
		map.addImage(id, data, { pixelRatio: ICON_PIXEL_RATIO });
	}

	function escapeHtml(s: string) {
		return s
			.replace(/&/g, '&amp;')
			.replace(/</g, '&lt;')
			.replace(/>/g, '&gt;')
			.replace(/"/g, '&quot;');
	}

	function popupHtml(props: Record<string, string | undefined>) {
		const title = escapeHtml(props.name || '');
		const sub = props.ref ? `<div class="mapbox-popup-ref">Sortie&nbsp;${escapeHtml(props.ref)}</div>` : '';
		const detail = props.detail ? `<p>${escapeHtml(props.detail)}</p>` : '';
		return `<div class="mapbox-popup-inner"><strong>${title}</strong>${sub}${detail}</div>`;
	}

	function boundsFromGeoJSON(fc: typeof transitFc): mapboxgl.LngLatBounds {
		const b = new mapboxgl.LngLatBounds();
		for (const f of fc.features) {
			if (f.geometry?.type === 'Point') {
				const c = f.geometry.coordinates as [number, number];
				b.extend(c);
			}
		}
		return b;
	}

	function boot() {
		const el = document.getElementById('map-acces');
		if (!el || el.dataset.mapReady) return;
		const token = (el.getAttribute('data-mapbox-token') || '').trim();
		if (!token) return;

		el.dataset.mapReady = '1';
		mapboxgl.accessToken = token;

		const style = el.dataset.style || '';
		const map = new mapboxgl.Map({
			container: el,
			style,
			center: [2.4358, 48.8582],
			zoom: 16,
			scrollZoom: false,
			attributionControl: true,
		});

		map.addControl(new mapboxgl.NavigationControl({ showCompass: false }), 'top-left');

		map.on('load', async () => {
			for (const [id, path] of Object.entries(ICON_URLS)) {
				try {
					await addRasterIcon(map, id, path);
				} catch (e) {
					console.warn(`[plan-dacces] Icône ${id} :`, e);
				}
			}

			map.addSource('transit', {
				type: 'geojson',
				data: transitFc,
			});

			if (map.hasImage('bb-bus')) {
				map.addLayer({
					id: 'transit-bus',
					type: 'symbol',
					source: 'transit',
					filter: ['==', ['get', 'kind'], 'bus'],
					layout: {
						'icon-image': 'bb-bus',
						'icon-size': 0.88,
						'icon-anchor': 'center',
						'icon-allow-overlap': true,
						'icon-ignore-placement': true,
					},
				});
			} else {
				map.addLayer({
					id: 'transit-bus',
					type: 'circle',
					source: 'transit',
					filter: ['==', ['get', 'kind'], 'bus'],
					paint: {
						'circle-radius': 5,
						'circle-color': '#0d8050',
						'circle-stroke-width': 2,
						'circle-stroke-color': '#ffffff',
					},
				});
			}

			if (map.hasImage('bb-exit')) {
				map.addLayer({
					id: 'transit-exit',
					type: 'symbol',
					source: 'transit',
					filter: ['==', ['get', 'kind'], 'exit'],
					layout: {
						'icon-image': 'bb-exit',
						'icon-size': 0.92,
						'icon-anchor': 'center',
						'icon-allow-overlap': true,
						'icon-ignore-placement': true,
					},
				});
			} else {
				map.addLayer({
					id: 'transit-exit',
					type: 'circle',
					source: 'transit',
					filter: ['==', ['get', 'kind'], 'exit'],
					paint: {
						'circle-radius': 7,
						'circle-color': '#e6c200',
						'circle-stroke-width': 2,
						'circle-stroke-color': '#1a1a1a',
					},
				});
			}

			if (map.hasImage('bb-metro')) {
				map.addLayer({
					id: 'transit-station',
					type: 'symbol',
					source: 'transit',
					filter: ['==', ['get', 'kind'], 'station'],
					layout: {
						'icon-image': 'bb-metro',
						'icon-size': 1,
						'icon-anchor': 'center',
						'icon-allow-overlap': true,
						'icon-ignore-placement': true,
					},
				});
			} else {
				map.addLayer({
					id: 'transit-station',
					type: 'circle',
					source: 'transit',
					filter: ['==', ['get', 'kind'], 'station'],
					paint: {
						'circle-radius': 9,
						'circle-color': '#003d82',
						'circle-stroke-width': 2,
						'circle-stroke-color': '#ffffff',
					},
				});
			}

			if (map.hasImage('bb-venue')) {
				map.addLayer({
					id: 'transit-venue',
					type: 'symbol',
					source: 'transit',
					filter: ['==', ['get', 'kind'], 'venue'],
					layout: {
						'icon-image': 'bb-venue',
						'icon-size': 0.95,
						'icon-anchor': 'bottom',
						'icon-offset': [0, -4],
						'icon-allow-overlap': true,
						'icon-ignore-placement': true,
					},
				});
			} else {
				map.addLayer({
					id: 'transit-venue',
					type: 'circle',
					source: 'transit',
					filter: ['==', ['get', 'kind'], 'venue'],
					paint: {
						'circle-radius': 11,
						'circle-color': '#9a3412',
						'circle-stroke-width': 2,
						'circle-stroke-color': '#fff7ed',
					},
				});
			}

			map.fitBounds(boundsFromGeoJSON(transitFc), {
				padding: { top: 48, bottom: 52, left: 48, right: 48 },
				maxZoom: 17,
				duration: 0,
			});

			map.on('mousemove', (e) => {
				const feats = map.queryRenderedFeatures(e.point, { layers: INTERACTIVE_LAYERS });
				map.getCanvas().style.cursor = feats.length ? 'pointer' : '';
			});

			map.on('click', (e) => {
				const feats = map.queryRenderedFeatures(e.point, { layers: INTERACTIVE_LAYERS });
				const f = feats[0];
				if (!f?.properties) return;
				const p = f.properties as Record<string, string>;
				new mapboxgl.Popup({ maxWidth: '280px' })
					.setLngLat(e.lngLat)
					.setHTML(popupHtml(p))
					.addTo(map);
			});
		});

		const wrap = el.closest('.map-live');
		const fb = wrap?.querySelectorAll('.map-live-fallback');
		fb?.forEach((n) => n.remove());
	}

	if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
	else boot();
</script>

<style>
	h1 {
		margin-top: 0;
	}
	.map-live {
		position: relative;
		width: 100%;
		height: min(42vh, 420px);
		min-height: 280px;
		margin: 1.25rem 0 1.5rem;
		border-radius: 0.85rem;
		overflow: hidden;
		border: 1px solid color-mix(in srgb, var(--border) 70%, #c4bfb4);
		box-shadow: 0 2px 14px color-mix(in srgb, var(--fg) 5%, transparent);
		z-index: 0;
		background: #f2eee4;
	}
	.map-acces-inner {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		z-index: 2;
	}
	.map-live :global(.mapboxgl-ctrl-bottom-right) {
		display: flex;
		align-items: flex-end;
		gap: 0.25rem;
	}
	.map-live :global(.mapboxgl-ctrl-attrib) {
		font-size: 0.65rem;
		background: color-mix(in srgb, #f2eee4 92%, transparent) !important;
	}
	.map-live :global(.mapboxgl-ctrl-group button) {
		background: #fff;
		color: #1a1a1a;
	}
	.map-live-fallback {
		position: absolute;
		inset: 0;
		margin: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 1rem;
		background: #f2eee4;
		font-size: 0.95rem;
		z-index: 3;
		pointer-events: none;
		text-align: center;
	}
	.map-live-fallback--osm {
		pointer-events: none;
	}
	.map-live-fallback a {
		pointer-events: auto;
		font-weight: 600;
	}
	.map-live-fallback--token {
		font-size: 0.88rem;
		color: var(--muted, #5a5c52);
		padding: 1.25rem;
	}
	.map-live :global(.mapbox-popup-inner) {
		font-size: 0.85rem;
		line-height: 1.35;
	}
	.map-live :global(.mapbox-popup-inner p) {
		margin: 0.35rem 0 0;
	}
	.map-live :global(.mapbox-popup-ref) {
		font-size: 0.8rem;
		font-weight: 600;
		color: #003d82;
		margin-top: 0.15rem;
	}
</style>
