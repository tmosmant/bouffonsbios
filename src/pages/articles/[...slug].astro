---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { CATEGORY_SLUGS } from '../../site-config';

export async function getStaticPaths() {
	const posts = await getCollection('articles');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = await render(post);
const catSlug = CATEGORY_SLUGS[post.data.category];
---

<Layout title={`${post.data.title} — Bouffons Bios`} description={post.data.excerpt} current="articles" mainClass="site-main--article">
	<article class="prose article-prose">
		<header class="article-head">
			<div class="article-meta">
				<a class="article-cat" href={`/articles/categorie/${catSlug}/`}>{post.data.category}</a>
				<time class="article-date" datetime={post.data.date.toISOString()}>
					{
						post.data.date.toLocaleDateString('fr-FR', {
							year: 'numeric',
							month: 'long',
							day: 'numeric',
						})
					}
				</time>
			</div>
			<h1>{post.data.title}</h1>
		</header>
		<div class="article-md">
			<Content />
		</div>
	</article>
	<nav class="article-bottom" aria-label="Navigation articles">
		<a class="article-bottom-link" href={`/articles/categorie/${catSlug}/`}>
			<span class="article-bottom-label">Catégorie</span>
			<span class="article-bottom-title">{post.data.category}</span>
		</a>
		<a class="article-bottom-link article-bottom-link--all" href="/articles/">
			<span class="article-bottom-label">Index</span>
			<span class="article-bottom-title">Tous les articles</span>
		</a>
	</nav>
</Layout>

<style>
	.article-prose {
		position: relative;
		margin: 0 -0.15rem;
		padding: 0;
		border-radius: 1.15rem;
		border: 1px solid color-mix(in srgb, var(--border) 75%, var(--accent-nature));
		background:
			radial-gradient(120% 80% at 100% 0%, color-mix(in srgb, var(--joy) 10%, transparent) 0%, transparent 55%),
			radial-gradient(90% 70% at 0% 100%, color-mix(in srgb, var(--accent-nature) 8%, transparent) 0%, transparent 50%),
			color-mix(in srgb, var(--bg) 97%, white);
		box-shadow:
			0 1px 2px color-mix(in srgb, var(--fg) 4%, transparent),
			0 16px 40px -24px color-mix(in srgb, var(--accent) 22%, transparent);
		overflow: hidden;
	}

	.article-head {
		padding: clamp(1.15rem, 3.5vw, 1.5rem) clamp(1.1rem, 3vw, 1.45rem) 1.1rem;
		border-bottom: 1px solid color-mix(in srgb, var(--border) 85%, var(--accent-nature));
		background: color-mix(in srgb, var(--bg) 55%, transparent);
		backdrop-filter: blur(10px);
	}

	.article-meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.5rem 0.75rem;
		margin-bottom: 0.85rem;
	}

	.article-cat {
		display: inline-flex;
		align-items: center;
		padding: 0.28rem 0.7rem;
		border-radius: 999px;
		font-size: 0.68rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.07em;
		text-decoration: none;
		color: var(--accent, #8f2d4a);
		background: linear-gradient(
			135deg,
			color-mix(in srgb, var(--accent-nature) 14%, transparent),
			color-mix(in srgb, var(--joy) 10%, transparent)
		);
		border: 1px solid color-mix(in srgb, var(--accent-nature) 28%, var(--border));
		transition:
			transform 0.15s ease,
			border-color 0.15s ease;
	}

	.article-cat:hover {
		border-color: color-mix(in srgb, var(--accent-nature) 50%, var(--joy));
		transform: translateY(-1px);
	}

	.article-date {
		font-size: 0.82rem;
		font-weight: 500;
		color: var(--muted, #5a5c52);
		font-variant-numeric: tabular-nums;
	}

	.article-head :global(h1) {
		margin: 0;
		font-size: clamp(1.45rem, 4.2vw, 2rem);
		line-height: 1.14;
		letter-spacing: -0.02em;
	}

	.article-md {
		padding: clamp(1.15rem, 3vw, 1.5rem) clamp(1.1rem, 3vw, 1.45rem) clamp(1.35rem, 3vw, 1.65rem);
	}

	.article-bottom {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0.65rem;
		margin-top: 1.35rem;
		padding: 0 0.1rem;
	}

	@media (max-width: 28rem) {
		.article-bottom {
			grid-template-columns: 1fr;
		}
	}

	.article-bottom-link {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
		padding: 0.75rem 0.9rem;
		border-radius: 0.75rem;
		text-decoration: none;
		color: inherit;
		border: 1px solid color-mix(in srgb, var(--border) 80%, var(--accent-nature));
		background: color-mix(in srgb, var(--accent-nature) 5%, transparent);
		transition:
			background 0.15s ease,
			border-color 0.15s ease,
			transform 0.15s ease;
	}

	.article-bottom-link:hover {
		background: linear-gradient(
			135deg,
			color-mix(in srgb, var(--accent-nature) 11%, transparent),
			color-mix(in srgb, var(--joy) 8%, transparent)
		);
		border-color: color-mix(in srgb, var(--accent-nature) 35%, var(--border));
		transform: translateY(-1px);
	}

	.article-bottom-link--all {
		background: color-mix(in srgb, var(--joy) 6%, transparent);
	}

	.article-bottom-label {
		font-size: 0.65rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--muted, #5a5c52);
	}

	.article-bottom-title {
		font-size: 0.92rem;
		font-weight: 600;
		color: var(--accent-nature, #35624a);
		line-height: 1.25;
	}

	.article-bottom-link:hover .article-bottom-title {
		color: var(--accent, #8f2d4a);
	}
</style>

<style is:global>
	/* Corps Markdown (hors fichier .astro → sélecteurs globaux, limités à .article-prose) */
	.article-prose .article-md {
		min-width: 0;
	}

	.article-prose .article-md > :first-child {
		margin-top: 0;
	}

	.article-prose .article-md > :last-child {
		margin-bottom: 0;
	}

	.article-prose .article-md :where(p) {
		font-size: 1.04rem;
		line-height: 1.72;
		margin: 0 0 1.15em;
	}

	.article-prose .article-md :where(h2) {
		margin: 2rem 0 0.65rem;
		padding-top: 1.35rem;
		border-top: 1px solid color-mix(in srgb, var(--border) 90%, var(--accent-nature));
		font-size: 1.2rem;
		letter-spacing: -0.02em;
	}

	.article-prose .article-md :where(h2):first-child {
		margin-top: 0;
		padding-top: 0;
		border-top: none;
	}

	.article-prose .article-md :where(h3) {
		margin: 1.5rem 0 0.5rem;
		font-size: 1.05rem;
	}

	.article-prose .article-md :where(ul, ol) {
		margin: 0 0 1.15em;
		padding-left: 1.35rem;
	}

	.article-prose .article-md :where(li) {
		margin: 0.35em 0;
		line-height: 1.65;
	}

	.article-prose .article-md :where(blockquote) {
		margin: 1.5rem 0;
		padding: 1rem 1.1rem;
		border-radius: 0.75rem;
		border-left-width: 3px;
		font-size: 0.98rem;
	}

	.article-prose .article-md :where(img) {
		margin: 1.35rem 0;
		border-radius: 0.85rem;
	}

	.article-prose .article-md :where(a) {
		text-decoration-thickness: 0.06em;
		text-underline-offset: 0.18em;
	}

	.article-prose .article-md :where(hr) {
		margin: 2.25rem 0;
	}

	.article-prose .article-md :where(pre) {
		margin: 1.25rem 0;
		font-size: 0.86rem;
		border-radius: 0.75rem;
	}

</style>
