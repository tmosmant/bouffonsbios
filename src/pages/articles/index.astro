---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { ARTICLE_CATEGORIES, CATEGORY_SLUGS, type ArticleCategory } from '../../site-config';

const posts = (await getCollection('articles')).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

function counts(): Record<ArticleCategory, number> {
	const init: Record<ArticleCategory, number> = {
		Affiches: 0,
		'Communiqués de presse': 0,
		'Non classé': 0,
		Vignerons: 0,
	};
	for (const p of posts) {
		init[p.data.category] += 1;
	}
	return init;
}

const byCat = counts();
---

<Layout title="Articles — Bouffons Bios" description="Articles et actualités" current="articles">
	<h1>Articles</h1>
	<p class="intro">Communiqués, listes de vignerons, affiches et textes du site.</p>

	<nav class="filters" aria-label="Filtrer par catégorie">
		<a href="/articles/" class="chip chip-all" aria-current="page">Toutes</a>
		{
			ARTICLE_CATEGORIES.map((label) => (
				<a href={`/articles/categorie/${CATEGORY_SLUGS[label]}/`} class="chip">
					{label}
					<span class="count">{byCat[label]}</span>
				</a>
			))
		}
	</nav>

	<ul class="list">
		{
			posts.map((post) => (
				<li>
					<a class="cat" href={`/articles/categorie/${CATEGORY_SLUGS[post.data.category]}/`}>
						{post.data.category}
					</a>
					<a class="title" href={`/articles/${post.id}/`}>
						{post.data.title}
					</a>
					<time datetime={post.data.date.toISOString()}>
						{post.data.date.toLocaleDateString('fr-FR', {
							year: 'numeric',
							month: 'long',
							day: 'numeric',
						})}
					</time>
					{post.data.excerpt && <p class="excerpt">{post.data.excerpt}</p>}
				</li>
			))
		}
	</ul>
</Layout>

<style>
	h1 {
		margin-top: 0;
	}
	.intro {
		color: var(--muted, #5c5850);
		margin: 0 0 1.25rem;
		font-size: 0.98rem;
	}
	.filters {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
		margin-bottom: 1.75rem;
	}
	.chip {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		padding: 0.38rem 0.72rem;
		border-radius: 999px;
		font-size: 0.82rem;
		font-weight: 500;
		text-decoration: none;
		color: var(--muted, #5a5c52);
		background: color-mix(in srgb, var(--accent-nature) 8%, transparent);
		border: 1px solid var(--border, #dcd4c8);
		transition:
			transform 0.15s ease,
			box-shadow 0.15s ease,
			border-color 0.15s ease,
			background 0.15s ease,
			color 0.15s ease;
	}
	.chip:hover {
		color: var(--accent, #8f2d4a);
		border-color: color-mix(in srgb, var(--accent-nature) 45%, var(--border));
		background: linear-gradient(
			135deg,
			color-mix(in srgb, var(--joy) 12%, transparent),
			color-mix(in srgb, var(--accent-nature) 10%, transparent)
		);
		transform: translateY(-1px);
		box-shadow: 0 4px 14px color-mix(in srgb, var(--accent-nature) 12%, transparent);
	}
	.chip-all {
		background: linear-gradient(
			135deg,
			color-mix(in srgb, var(--accent) 14%, transparent),
			color-mix(in srgb, var(--joy) 10%, transparent)
		);
		color: var(--accent, #8f2d4a);
		border-color: color-mix(in srgb, var(--joy) 35%, transparent);
		font-weight: 600;
	}
	.count {
		opacity: 0.75;
		font-size: 0.78rem;
	}
	.list {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.list li {
		padding: 1rem 0.35rem;
		margin: 0 -0.35rem;
		border-bottom: 1px solid var(--border, #dcd4c8);
		border-radius: 0;
		transition: background 0.15s ease;
	}
	.list li:hover {
		background: linear-gradient(
			90deg,
			color-mix(in srgb, var(--joy) 5%, transparent),
			transparent 70%
		);
	}
	.list .cat {
		display: inline-block;
		font-size: 0.72rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		color: var(--accent-nature, #35624a);
		text-decoration: none;
		margin-bottom: 0.35rem;
	}
	.list .cat:hover {
		text-decoration: underline;
	}
	.list .title {
		display: block;
		font-weight: 600;
		font-size: 1.05rem;
		color: var(--fg, #1a1814);
		text-decoration: none;
	}
	.list .title:hover {
		color: var(--accent, #8f2d4a);
	}
	time {
		display: block;
		font-size: 0.85rem;
		color: var(--muted, #5c5850);
		margin-top: 0.35rem;
	}
	.excerpt {
		margin: 0.5rem 0 0;
		font-size: 0.95rem;
		color: var(--muted, #5c5850);
	}
</style>
