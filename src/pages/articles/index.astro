---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { ARTICLE_CATEGORIES, CATEGORY_SLUGS, type ArticleCategory } from '../../site-config';

const posts = (await getCollection('articles')).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

function counts(): Record<ArticleCategory, number> {
	const init: Record<ArticleCategory, number> = {
		Affiches: 0,
		'Communiqués de presse': 0,
		'Non classé': 0,
		Vignerons: 0,
	};
	for (const p of posts) {
		init[p.data.category] += 1;
	}
	return init;
}

const byCat = counts();
---

<Layout title="Articles — Bouffons Bios" description="Articles et actualités" current="articles" mainClass="site-main--narrow">
	<h1>Articles</h1>
	<p class="intro">Communiqués, listes de vignerons, affiches et textes du site.</p>

	<nav class="filters" aria-label="Filtrer par catégorie">
		<a href="/articles/" class="chip chip-all" aria-current="page">Toutes</a>
		{
			ARTICLE_CATEGORIES.map((label) => (
				<a href={`/articles/categorie/${CATEGORY_SLUGS[label]}/`} class="chip">
					{label}
					<span class="count">{byCat[label]}</span>
				</a>
			))
		}
	</nav>

	<ul class="article-list">
		{
			posts.map((post) => (
				<li>
					<article class="article-card">
						<div class="article-card__top">
							<time class="article-card__date" datetime={post.data.date.toISOString()}>
								{post.data.date.toLocaleDateString('fr-FR', {
									year: 'numeric',
									month: 'long',
									day: 'numeric',
								})}
							</time>
							<a class="article-card__cat" href={`/articles/categorie/${CATEGORY_SLUGS[post.data.category]}/`}>
								{post.data.category}
							</a>
						</div>
						<h2 class="article-card__title">
							<a href={`/articles/${post.id}/`}>{post.data.title}</a>
						</h2>
						{post.data.excerpt && <p class="article-card__excerpt">{post.data.excerpt}</p>}
					</article>
				</li>
			))
		}
	</ul>
</Layout>

<style>
	h1 {
		margin-top: 0;
		font-family: var(--font-display, Georgia, serif);
		font-weight: 800;
		letter-spacing: -0.02em;
	}
	.intro {
		color: var(--muted, #5c5850);
		margin: 0 0 1.25rem;
		font-size: 0.98rem;
		line-height: 1.5;
	}
	.filters {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
		margin-bottom: 1.75rem;
	}
	.chip {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		padding: 0.38rem 0.72rem;
		border-radius: 999px;
		font-size: 0.82rem;
		font-weight: 500;
		text-decoration: none;
		color: var(--muted, #5a5c52);
		background: color-mix(in srgb, var(--accent-nature) 8%, transparent);
		border: 1px solid var(--border, #dcd4c8);
		transition:
			transform 0.15s ease,
			box-shadow 0.15s ease,
			border-color 0.15s ease,
			background 0.15s ease,
			color 0.15s ease;
	}
	.chip:hover {
		color: var(--accent, #8f2d4a);
		border-color: color-mix(in srgb, var(--accent-nature) 45%, var(--border));
		background: linear-gradient(
			135deg,
			color-mix(in srgb, var(--joy) 12%, transparent),
			color-mix(in srgb, var(--accent-nature) 10%, transparent)
		);
		transform: translateY(-1px);
		box-shadow: 0 4px 14px color-mix(in srgb, var(--accent-nature) 12%, transparent);
	}
	.chip-all {
		background: linear-gradient(
			135deg,
			color-mix(in srgb, var(--accent) 14%, transparent),
			color-mix(in srgb, var(--joy) 10%, transparent)
		);
		color: var(--accent, #8f2d4a);
		border-color: color-mix(in srgb, var(--joy) 35%, transparent);
		font-weight: 600;
	}
	.count {
		opacity: 0.75;
		font-size: 0.78rem;
	}

	.article-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.article-card {
		margin: 0;
		padding: 1.05rem 1.15rem 1.2rem;
		border-radius: 0.95rem;
		border: 1px solid color-mix(in srgb, var(--border) 72%, var(--accent-nature));
		background: linear-gradient(
			168deg,
			color-mix(in srgb, var(--joy) 9%, var(--bg)) 0%,
			color-mix(in srgb, var(--accent-nature) 5%, var(--bg)) 48%,
			var(--bg) 100%
		);
		box-shadow:
			0 1px 0 color-mix(in srgb, var(--joy) 11%, transparent) inset,
			0 10px 32px -20px color-mix(in srgb, var(--accent) 22%, transparent);
		transition:
			border-color 0.2s ease,
			box-shadow 0.2s ease,
			transform 0.2s ease;
	}

	.article-card:hover {
		border-color: color-mix(in srgb, var(--accent-nature) 32%, var(--border));
		box-shadow:
			0 1px 0 color-mix(in srgb, var(--joy) 14%, transparent) inset,
			0 14px 40px -18px color-mix(in srgb, var(--accent) 28%, transparent);
		transform: translateY(-2px);
	}

	.article-card__top {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 0.5rem 0.75rem;
		margin-bottom: 0.55rem;
	}

	.article-card__date {
		font-size: 0.78rem;
		font-weight: 600;
		font-variant-numeric: tabular-nums;
		color: var(--muted, #5c5850);
		letter-spacing: 0.02em;
	}

	.article-card__cat {
		display: inline-flex;
		align-items: center;
		padding: 0.2rem 0.55rem;
		border-radius: 999px;
		font-size: 0.68rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.07em;
		text-decoration: none;
		color: var(--accent, #8f2d4a);
		background: color-mix(in srgb, var(--accent) 9%, transparent);
		border: 1px solid color-mix(in srgb, var(--accent) 22%, var(--border));
		transition:
			background 0.15s ease,
			border-color 0.15s ease,
			color 0.15s ease;
	}

	.article-card__cat:hover {
		background: color-mix(in srgb, var(--accent) 14%, transparent);
		border-color: color-mix(in srgb, var(--accent) 35%, var(--border));
		color: var(--accent-soft, #a84862);
	}

	.article-card__title {
		margin: 0;
		font-family: var(--font-display, Georgia, serif);
		font-size: clamp(1.08rem, 2.8vw, 1.28rem);
		font-weight: 800;
		line-height: 1.22;
		letter-spacing: -0.02em;
		text-rendering: optimizeLegibility;
	}

	.article-card__title a {
		color: var(--fg, #1c221c);
		text-decoration: none;
		transition: color 0.15s ease;
	}

	.article-card__title a:hover {
		color: var(--accent, #8f2d4a);
	}

	.article-card__excerpt {
		margin: 0.55rem 0 0;
		font-size: 0.9rem;
		line-height: 1.55;
		color: var(--muted, #5c5850);
		display: -webkit-box;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 3;
		overflow: hidden;
	}
</style>
