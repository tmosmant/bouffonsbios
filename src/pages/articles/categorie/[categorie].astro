---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import { CATEGORY_SLUGS, categoryFromSlug, ARTICLE_CATEGORIES, type ArticleCategory } from '../../../site-config';

export async function getStaticPaths() {
	return Object.values(CATEGORY_SLUGS).map((slug) => ({
		params: { categorie: slug },
	}));
}

const raw = Astro.params.categorie;
const label = categoryFromSlug(raw ?? '');
if (!label) {
	throw new Error(`Catégorie inconnue : ${raw}`);
}

const allPosts = await getCollection('articles');
const posts = allPosts
	.filter(({ data }) => data.category === label)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const byCat: Record<ArticleCategory, number> = {
	Affiches: 0,
	'Communiqués de presse': 0,
	'Non classé': 0,
	Vignerons: 0,
};
for (const p of allPosts) {
	byCat[p.data.category] += 1;
}
---

<Layout title={`${label} — Articles — Bouffons Bios`} description={`Articles : ${label}`} current="articles">
	<h1>{label}</h1>
	<p class="intro">
		<a href="/articles/">← Toutes les catégories</a>
	</p>

	<nav class="filters" aria-label="Filtrer par catégorie">
		<a href="/articles/" class="chip">Toutes</a>
		{
			ARTICLE_CATEGORIES.map((cat) => (
				<a
					href={`/articles/categorie/${CATEGORY_SLUGS[cat]}/`}
					class:list={['chip', { 'chip-active': cat === label }]}
					aria-current={cat === label ? 'page' : undefined}
				>
					{cat}
					<span class="count">{byCat[cat]}</span>
				</a>
			))
		}
	</nav>

	<ul class="list">
		{
			posts.map((post) => (
				<li>
					<a class="title" href={`/articles/${post.id}/`}>
						{post.data.title}
					</a>
					<time datetime={post.data.date.toISOString()}>
						{post.data.date.toLocaleDateString('fr-FR', {
							year: 'numeric',
							month: 'long',
							day: 'numeric',
						})}
					</time>
					{post.data.excerpt && <p class="excerpt">{post.data.excerpt}</p>}
				</li>
			))
		}
	</ul>
</Layout>

<style>
	h1 {
		margin-top: 0;
	}
	.intro {
		margin: 0 0 1.25rem;
		font-size: 0.95rem;
	}
	.intro a {
		color: var(--accent-nature, #35624a);
		font-weight: 600;
	}
	.intro a:hover {
		color: var(--accent, #8f2d4a);
	}
	.filters {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
		margin-bottom: 1.75rem;
	}
	.chip {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		padding: 0.38rem 0.72rem;
		border-radius: 999px;
		font-size: 0.82rem;
		font-weight: 500;
		text-decoration: none;
		color: var(--muted, #5a5c52);
		background: color-mix(in srgb, var(--accent-nature) 8%, transparent);
		border: 1px solid var(--border, #dcd4c8);
		transition:
			transform 0.15s ease,
			box-shadow 0.15s ease,
			border-color 0.15s ease,
			background 0.15s ease,
			color 0.15s ease;
	}
	.chip:hover {
		color: var(--accent, #8f2d4a);
		border-color: color-mix(in srgb, var(--accent-nature) 45%, var(--border));
		background: linear-gradient(
			135deg,
			color-mix(in srgb, var(--joy) 12%, transparent),
			color-mix(in srgb, var(--accent-nature) 10%, transparent)
		);
		transform: translateY(-1px);
		box-shadow: 0 4px 14px color-mix(in srgb, var(--accent-nature) 12%, transparent);
	}
	.chip-active {
		background: linear-gradient(
			135deg,
			color-mix(in srgb, var(--accent) 16%, transparent),
			color-mix(in srgb, var(--joy) 12%, transparent)
		);
		color: var(--accent, #8f2d4a);
		border-color: color-mix(in srgb, var(--joy) 40%, var(--accent));
		font-weight: 600;
	}
	.count {
		opacity: 0.75;
		font-size: 0.78rem;
	}
	.list {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.list li {
		padding: 1rem 0.35rem;
		margin: 0 -0.35rem;
		border-bottom: 1px solid var(--border, #dcd4c8);
		transition: background 0.15s ease;
	}
	.list li:hover {
		background: linear-gradient(
			90deg,
			color-mix(in srgb, var(--joy) 5%, transparent),
			transparent 70%
		);
	}
	.list .title {
		font-weight: 600;
		font-size: 1.05rem;
		color: var(--fg, #1c221c);
		text-decoration: none;
		transition: color 0.15s ease;
	}
	.list .title:hover {
		color: var(--accent, #8f2d4a);
		text-decoration: underline;
		text-decoration-color: color-mix(in srgb, var(--joy) 70%, var(--accent));
	}
	time {
		display: block;
		font-size: 0.85rem;
		color: var(--muted, #5c5850);
		margin-top: 0.35rem;
	}
	.excerpt {
		margin: 0.5rem 0 0;
		font-size: 0.95rem;
		color: var(--muted, #5c5850);
	}
</style>
