---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import { CATEGORY_SLUGS, categoryFromSlug, ARTICLE_CATEGORIES, type ArticleCategory } from '../../../site-config';

export async function getStaticPaths() {
	return Object.values(CATEGORY_SLUGS).map((slug) => ({
		params: { categorie: slug },
	}));
}

const raw = Astro.params.categorie;
const label = categoryFromSlug(raw ?? '');
if (!label) {
	throw new Error(`Catégorie inconnue : ${raw}`);
}

const allPosts = await getCollection('articles');
const posts = allPosts
	.filter(({ data }) => data.category === label)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const byCat: Record<ArticleCategory, number> = {
	Affiches: 0,
	'Communiqués de presse': 0,
	'Non classé': 0,
	Vignerons: 0,
};
for (const p of allPosts) {
	byCat[p.data.category] += 1;
}
---

<Layout title={`${label} — Articles — Bouffons Bios`} description={`Articles : ${label}`} current="articles">
	<h1>{label}</h1>
	<p class="intro">
		<a href="/articles/">← Toutes les catégories</a>
	</p>

	<nav class="filters" aria-label="Filtrer par catégorie">
		<a href="/articles/" class="chip">Toutes</a>
		{
			ARTICLE_CATEGORIES.map((cat) => (
				<a
					href={`/articles/categorie/${CATEGORY_SLUGS[cat]}/`}
					class:list={['chip', { 'chip-active': cat === label }]}
					aria-current={cat === label ? 'page' : undefined}
				>
					{cat}
					<span class="count">{byCat[cat]}</span>
				</a>
			))
		}
	</nav>

	<ul class="list">
		{
			posts.map((post) => (
				<li>
					<a class="title" href={`/articles/${post.id}/`}>
						{post.data.title}
					</a>
					<time datetime={post.data.date.toISOString()}>
						{post.data.date.toLocaleDateString('fr-FR', {
							year: 'numeric',
							month: 'long',
							day: 'numeric',
						})}
					</time>
					{post.data.excerpt && <p class="excerpt">{post.data.excerpt}</p>}
				</li>
			))
		}
	</ul>
</Layout>

<style>
	h1 {
		margin-top: 0;
	}
	.intro {
		margin: 0 0 1.25rem;
		font-size: 0.95rem;
	}
	.intro a {
		color: var(--accent, #6b3d2e);
	}
	.filters {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
		margin-bottom: 1.75rem;
	}
	.chip {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		padding: 0.35rem 0.65rem;
		border-radius: 999px;
		font-size: 0.82rem;
		font-weight: 500;
		text-decoration: none;
		color: var(--muted, #5c5850);
		background: color-mix(in srgb, var(--muted) 12%, transparent);
		border: 1px solid var(--border, #e0dbd4);
	}
	.chip:hover {
		color: var(--accent, #6b3d2e);
	}
	.chip-active {
		background: color-mix(in srgb, var(--accent) 18%, transparent);
		color: var(--accent, #6b3d2e);
		border-color: var(--accent, #6b3d2e);
	}
	.count {
		opacity: 0.75;
		font-size: 0.78rem;
	}
	.list {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.list li {
		padding: 1rem 0;
		border-bottom: 1px solid var(--border, #e0dbd4);
	}
	.list .title {
		font-weight: 600;
		font-size: 1.05rem;
		color: var(--accent, #6b3d2e);
		text-decoration: none;
	}
	.list .title:hover {
		text-decoration: underline;
	}
	time {
		display: block;
		font-size: 0.85rem;
		color: var(--muted, #5c5850);
		margin-top: 0.35rem;
	}
	.excerpt {
		margin: 0.5rem 0 0;
		font-size: 0.95rem;
		color: var(--muted, #5c5850);
	}
</style>
