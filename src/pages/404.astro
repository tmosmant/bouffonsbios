---
import Layout from '../layouts/Layout.astro';

Astro.response.status = 404;

const title = 'Page introuvable — Bouffons Bios';
const description =
	'Erreur 404 : cette page n’existe pas ou a été déplacée. Retournez à l’accueil ou explorez le site.';
---

<Layout
	title={title}
	description={description}
	mainClass="site-main--narrow"
	openGraph={{
		title,
		description,
		image: '/uploads/404-perdu-dans-les-vignes.png',
		imageAlt:
			'Illustration humoristique : visiteur perdu dans une vigne, verre de vin vide, points d’interrogation',
		type: 'website',
	}}
>
	<meta slot="head" name="robots" content="noindex, nofollow" />
	<article class="not-found">
		<p class="not-found__code" aria-hidden="true">404</p>
		<h1>Perdu dans les vignes</h1>
		<p class="not-found__lead">
			On a cherché partout — <strong>même les raisins n’ont aucune idée</strong> de l’endroit où se cache cette page.
		</p>

		<figure class="not-found__figure">
			<img
				class="not-found__img"
				src="/uploads/404-perdu-dans-les-vignes.png"
				alt="Dessin humoristique : homme égaré au milieu des vignes, verre vide à la main, grappes de raisin avec des visages perplexes et points d’interrogation."
				width="770"
				height="610"
				loading="eager"
				decoding="async"
			/>
		</figure>

		<p class="not-found__hint">
			La page a peut‑être fini en <strong>bouchon</strong>, ou l’URL contient une coquille. Pas de panique : le bon cru, c’est par ici.
		</p>

		<nav class="not-found__actions" aria-label="Pages utiles">
			<a class="not-found__btn not-found__btn--primary" href="/">Retour à l’accueil</a>
			<a class="not-found__btn" href="/articles/">Articles</a>
			<a class="not-found__btn" href="/contact/">Contact</a>
		</nav>
	</article>
</Layout>

<style>
	.not-found {
		text-align: center;
		padding: 0.25rem 0 2rem;
	}

	.not-found__code {
		margin: 0 0 0.35rem;
		font-family: var(--font-display, Georgia, serif);
		font-weight: 800;
		font-size: clamp(2.5rem, 8vw, 3.25rem);
		line-height: 1;
		letter-spacing: -0.04em;
		color: color-mix(in srgb, var(--accent) 35%, var(--muted));
		opacity: 0.85;
	}

	.not-found h1 {
		margin: 0 0 0.75rem;
		font-family: var(--font-display, Georgia, serif);
		font-weight: 800;
		font-size: clamp(1.5rem, 4.5vw, 1.85rem);
		line-height: 1.15;
		letter-spacing: -0.02em;
		color: var(--fg);
	}

	.not-found__lead {
		margin: 0 auto 1.25rem;
		max-width: 32rem;
		font-size: 1.02rem;
		line-height: 1.5;
		color: var(--muted);
	}

	.not-found__figure {
		margin: 0 auto 1.25rem;
		max-width: min(100%, 28rem);
		padding: 0.75rem;
		border-radius: 1rem;
		background: linear-gradient(
			165deg,
			color-mix(in srgb, var(--joy) 10%, var(--bg)),
			color-mix(in srgb, var(--accent-nature) 6%, var(--bg))
		);
		border: 1px solid color-mix(in srgb, var(--border) 75%, var(--accent-nature));
		box-shadow: 0 10px 36px -16px color-mix(in srgb, var(--accent) 25%, transparent);
	}

	.not-found__img {
		display: block;
		width: 100%;
		height: auto;
		border-radius: 0.65rem;
	}

	.not-found__hint {
		margin: 0 auto 1.5rem;
		max-width: 30rem;
		font-size: 0.92rem;
		line-height: 1.5;
		color: var(--muted);
	}

	.not-found__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
		justify-content: center;
		align-items: center;
	}

	.not-found__btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.58rem 1.1rem;
		border-radius: 0.65rem;
		font-size: 0.9rem;
		font-weight: 600;
		text-decoration: none;
		border: 1.5px solid color-mix(in srgb, var(--border) 80%, var(--accent-nature));
		background: color-mix(in srgb, var(--bg) 88%, transparent);
		color: var(--fg);
		transition:
			background 0.15s ease,
			border-color 0.15s ease,
			color 0.15s ease;
	}

	.not-found__btn:hover {
		border-color: color-mix(in srgb, var(--accent-nature) 40%, var(--border));
		background: color-mix(in srgb, var(--accent-nature) 8%, var(--bg));
		color: var(--accent-nature);
	}

	.not-found__btn--primary {
		border-color: color-mix(in srgb, var(--accent-nature) 45%, var(--border));
		background: linear-gradient(
			145deg,
			color-mix(in srgb, var(--accent-nature) 18%, var(--bg)),
			color-mix(in srgb, var(--joy) 12%, var(--bg))
		);
		color: var(--accent-nature);
		font-weight: 700;
	}

	.not-found__btn--primary:hover {
		border-color: var(--accent-nature);
		background: linear-gradient(
			145deg,
			color-mix(in srgb, var(--accent-nature) 26%, var(--bg)),
			color-mix(in srgb, var(--joy) 16%, var(--bg))
		);
		color: var(--fg);
	}
</style>
